---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { getLang, getAlternateUrl } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Rij-Vrij biedt professionele opfrislessen voor bestuurders die al een rijbewijs hebben. Automaat, regio Haaglanden, Delft & Zoetermeer. Specialist autisme & ADHD.',
  ogImage = '/og-image.png',
} = Astro.props;

const lang = getLang(Astro.url.pathname);
const canonicalURL = new URL(Astro.url.pathname, 'https://rij-vrij.nl');
const alternateUrl = getAlternateUrl(Astro.url.pathname);
const alternateAbsolute = new URL(alternateUrl, 'https://rij-vrij.nl');
const defaultDescription = 'Rij-Vrij biedt professionele opfrislessen voor bestuurders die al een rijbewijs hebben. Automaat, regio Haaglanden, Delft & Zoetermeer. Specialist autisme & ADHD.';
const fullTitle = `${title} | Rij-Vrij Opfrislessen`;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang={lang === 'nl' ? 'en' : 'nl'} href={alternateAbsolute.href} />
    <link rel="alternate" hreflang={lang} href={canonicalURL.href} />
    <link rel="alternate" hreflang="x-default" href={lang === 'nl' ? canonicalURL.href : alternateAbsolute.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://rij-vrij.nl${ogImage}`} />
    <meta property="og:locale" content={lang === 'en' ? 'en_GB' : 'nl_NL'} />
    <meta property="og:site_name" content="Rij-Vrij Rijschool" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://rij-vrij.nl${ogImage}`} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/rij-vrij-logo.png" />
    <link rel="apple-touch-icon" href="/rij-vrij-logo.png" />

    <!-- Vroege verbindingen met externe origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- DM Sans – niet-blokkerend -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700;9..40,800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700;9..40,800&display=swap"
      />
    </noscript>

    <style>
      body { font-family: 'DM Sans', ui-sans-serif, system-ui, sans-serif; }
    </style>

    <!-- Pagina-specifieke head-tags (bv. preload LCP-afbeelding, JSON-LD schema) -->
    <slot name="head" />
  </head>
  <body class="bg-[#faf8f4] text-[#1a1a18]">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- WhatsApp floating button -->
    <a
      href="https://wa.me/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="WhatsApp"
      style="position:fixed;bottom:24px;right:24px;z-index:200;width:56px;height:56px;border-radius:50%;background:#25D366;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,0.45);transition:transform 0.15s,box-shadow 0.15s"
      onmouseover="this.style.transform='scale(1.1)';this.style.boxShadow='0 6px 28px rgba(37,211,102,0.55)'"
      onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 4px 20px rgba(37,211,102,0.45)'"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="28" height="28" fill="white" aria-hidden="true">
        <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
      </svg>
    </a>

    <!-- Tekstlabels voor redactie: activeer met ?labels=1 in de URL -->
    <script>
    (function () {
      if (!new URLSearchParams(window.location.search).has('labels')) return;

      const SELECTORS = 'h1, h2, h3, h4, h5, h6, p, li, a, button, th, td, label, span';
      const SKIP_TAGS = new Set(['SCRIPT', 'STYLE', 'NOSCRIPT', 'SVG', 'PATH']);

      let counter = 0;
      const log: {num: number; tekst: string; pagina: string}[] = [];
      const pagina = document.title.split('|')[0].trim();

      document.querySelectorAll<HTMLElement>(SELECTORS).forEach((el) => {
        if (SKIP_TAGS.has(el.tagName)) return;
        if (el.closest('[data-lbl]')) return;
        const tekst = el.textContent?.replace(/\s+/g, ' ').trim() ?? '';
        if (tekst.length < 2) return;

        counter++;
        el.setAttribute('data-lbl', String(counter));
        log.push({ num: counter, tekst: tekst.substring(0, 80), pagina });

        const badge = document.createElement('span');
        badge.setAttribute('data-lbl-badge', '');
        badge.textContent = String(counter);
        badge.style.cssText = [
          'display:inline-flex',
          'align-items:center',
          'justify-content:center',
          'background:#f97316',
          'color:#fff',
          'font-size:10px',
          'font-weight:700',
          'font-family:monospace',
          'min-width:17px',
          'height:17px',
          'border-radius:9px',
          'padding:0 3px',
          'margin-right:3px',
          'vertical-align:middle',
          'line-height:1',
          'position:relative',
          'z-index:10000',
          'cursor:pointer',
          'flex-shrink:0',
        ].join(';');

        badge.title = `#${counter}: ${tekst.substring(0, 60)}`;
        badge.addEventListener('click', (e) => {
          e.stopPropagation();
          prompt(`Nummer ${counter} — huidige tekst:`, tekst);
        });

        el.insertBefore(badge, el.firstChild);
      });

      // Zwevend info-paneel onderaan
      const panel = document.createElement('div');
      panel.style.cssText = [
        'position:fixed',
        'bottom:0',
        'left:0',
        'right:0',
        'background:#1e293b',
        'color:#fff',
        'font-size:13px',
        'font-family:monospace',
        'padding:10px 16px',
        'z-index:99999',
        'display:flex',
        'align-items:center',
        'justify-content:space-between',
        'gap:12px',
        'flex-wrap:wrap',
      ].join(';');

      panel.innerHTML = `
        <span>🟠 <strong>${counter} tekstelementen</strong> genummerd op pagina "<strong>${pagina}</strong>"</span>
        <span style="color:#f97316">Stuur: pagina + nummer + nieuwe tekst → dan pas ik het aan</span>
        <button onclick="
          const lines = ${JSON.stringify(log)}.map(r => r.num + '. ' + r.tekst).join('\\n');
          const blob = new Blob([lines], {type:'text/plain'});
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = 'labels-${pagina.toLowerCase().replace(/\\s+/g,'-')}.txt';
          a.click();
        " style="background:#f97316;color:#fff;border:none;border-radius:6px;padding:5px 12px;cursor:pointer;font-size:12px;font-weight:700;">
          ↓ Download lijst
        </button>
      `;
      document.body.appendChild(panel);
    })();
    </script>
  </body>
</html>
