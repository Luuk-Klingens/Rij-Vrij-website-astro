---
import Layout from '../../layouts/Layout.astro';
import lesgebieden from '../../data/lesgebieden';

export const prerender = true;

const primaryColor = '#223927';
const secondaryColor = '#ac884d';

const examenlocaties = [
  { stad: 'Rijswijk', adres: 'CBR Rijswijk, Zuid-Holland' },
  { stad: 'Zoetermeer', adres: 'CBR Zoetermeer, Zuid-Holland' },
];
import Icon from '../../components/Icon.astro';
---

<Layout
  title="Lesgebieden"
  description="Rij-Vrij Rijschool geeft RijVrij rijlessen in 15 gemeenten in de regio Haaglanden, Delft en Zoetermeer. Bekijk alle lesgebieden en vind jouw rijschool in de buurt."
>
  <div class="bg-white">

    <!-- Header -->
    <section class="py-20" style={`background-color: ${primaryColor}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-white text-sm font-semibold uppercase tracking-widest mb-3">Waar geven wij les?</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Lesgebieden</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">
          Rij-Vrij geeft RijVrij rijlessen in 15 gemeenten in de regio Haaglanden, Delft en Zoetermeer. Klik op jouw gemeente voor meer informatie.
        </p>
        <div class="mt-8 flex justify-center gap-6 flex-wrap">
          <div class="bg-white/20 backdrop-blur-sm border border-white/30 text-white px-6 py-3 rounded-xl text-center">
            <div class="text-3xl font-bold">15</div>
            <div class="text-sm opacity-80">gemeenten</div>
          </div>
          <div class="bg-white/20 backdrop-blur-sm border border-white/30 text-white px-6 py-3 rounded-xl text-center">
            <div class="text-3xl font-bold">2</div>
            <div class="text-sm opacity-80">examenlocaties</div>
          </div>
          <div class="bg-white/20 backdrop-blur-sm border border-white/30 text-white px-6 py-3 rounded-xl text-center">
            <div class="text-3xl font-bold">Zuid</div>
            <div class="text-sm opacity-80">Holland</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gemeenten grid -->
    <section class="py-20 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Kies jouw gemeente</h2>
          <p class="text-gray-600 max-w-xl mx-auto">
            Klik op jouw woonplaats voor meer informatie over rijles in jouw buurt.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {lesgebieden.map((g) => (
            <a
              href={`/lesgebied/${g.slug}`}
              class="flex items-center justify-between p-5 rounded-xl border border-gray-100 bg-gray-50 hover:shadow-md hover:border-gray-200 transition-all group"
            >
              <div class="flex items-center gap-4">
                <div
                  class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform"
                  style={`background-color: ${primaryColor}15`}
                >
                  <Icon name="map-pin" class="text-sm" style={`color: ${primaryColor}`} />
                </div>
                <div>
                  <p class="font-semibold text-gray-900">{g.naam}</p>
                  <p class="text-xs text-gray-600 mt-0.5">
                    <Icon name="graduation-cap" class="mr-1" />
                    Examen: {g.examen.join(' & ')}
                  </p>
                </div>
              </div>
              <Icon name="chevron-right" class="text-gray-400 group-hover:text-gray-600 group-hover:translate-x-1 transition-all text-xs" />
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Examenlocaties -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Examenlocaties</h2>
          <p class="text-gray-600 text-sm">Wij rijden je naar het CBR-examen. Geen extra kosten.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {examenlocaties.map((loc) => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 text-center">
              <div
                class="w-14 h-14 rounded-xl flex items-center justify-center mx-auto mb-4"
                style={`background-color: ${secondaryColor}15`}
              >
                <Icon name="flag-checkered" class="text-xl" style={`color: ${secondaryColor}`} />
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-1">CBR {loc.stad}</h3>
              <p class="text-gray-600 text-sm">{loc.adres}</p>
            </div>
          ))}
        </div>
        <p class="text-center text-sm text-gray-600 mt-6">
          Wij rijden je naar de examenlocatie. Op locatie heb je de keuze of je de instructeur meeneemt of niet.
        </p>
      </div>
    </section>

    <!-- Staat jouw gemeente er niet bij? -->
    <section class="py-12 bg-white border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <div
          class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4"
          style={`background-color: ${primaryColor}15`}
        >
          <Icon name="question" class="text-xl" style={`color: ${primaryColor}`} />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Staat jouw woonplaats er niet bij?</h3>
        <p class="text-gray-600 text-sm mb-6">
          Neem contact op. Wij kijken graag of we ook in jouw regio rijles kunnen geven.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md"
            style={`background-color: ${primaryColor}`}
          >
            <Icon name="envelope" class="mr-2" />Neem contact op
          </a>
          <a
            href="/#proefles-cta"
            class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md"
            style={`background-color: ${secondaryColor}`}
          >
            <Icon name="calendar-check" class="mr-2" />Plan je proefles
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>
