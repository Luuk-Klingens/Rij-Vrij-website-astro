---
import Layout from '../layouts/Layout.astro';
import GoogleReviews from '../components/GoogleReviews.astro';

const primaryColor = '#0391b0';
const secondaryColor = '#790f34';
import Icon from '../components/Icon.astro';
---

<Layout
  title="Reviews & Ervaringen"
  description="Lees wat leerlingen zeggen over Rij-Vrij Rijschool. Gemiddeld 5 sterren op Google. Bekijk ervaringen en laat zelf een review achter."
>
  <div class="bg-white">

    <!-- Header -->
    <section class="py-16" style={`background: linear-gradient(135deg, ${primaryColor} 0%, ${secondaryColor} 100%)`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Wat zeggen onze leerlingen?</h1>
        <p class="text-white/90 max-w-3xl mx-auto mt-4 text-lg">
          Ontdek wat onze cursisten zeggen over hun ervaring bij Rij-Vrij.
        </p>
      </div>
    </section>

    <!-- Reviews info sectie -->
    <section class="py-20 bg-gray-50">
      <!-- Stats: smal gecentreerd -->
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center mb-12">
        <div
          class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6"
          style={`background-color: ${primaryColor}15`}
        >
          <Icon name="star" class="text-3xl" style={`color: ${primaryColor}`} />
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Onze leerlingen waarderen ons hoog</h2>
        <p class="text-gray-600 leading-relaxed mb-8 max-w-2xl mx-auto">
          Rij-Vrij ontvangt uitstekende beoordelingen op Google. Wij staan voor persoonlijk contact, hoog slagingspercentage en rijles die echt aansluit bij jouw tempo en leerstijl.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="flex justify-center gap-1 mb-2">
              {[...Array(5)].map(() => (
                <Icon name="star" class="text-yellow-400 text-2xl" />
              ))}
            </div>
            <p class="text-gray-600 text-sm font-medium">5 sterren op Google</p>
            <p class="text-xs text-gray-500 mt-1">Gemiddelde beoordeling</p>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="text-4xl font-black mb-2" style={`color: ${primaryColor}`}>100%</div>
            <p class="text-gray-600 text-sm font-medium">Zou ons aanbevelen</p>
            <Icon name="thumbs-up" class="mt-2 text-2xl" style={`color: ${primaryColor}`} />
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <Icon name="handshake" class="text-3xl mb-2" style={`color: ${primaryColor}`} />
            <p class="text-gray-600 text-sm font-medium">Transparant & eerlijk</p>
            <p class="text-xs text-gray-400 mt-2">Geen verborgen kosten</p>
          </div>
        </div>
      </div>

      <!-- Reviews: breed voor goede 3-koloms weergave -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h3 class="text-xl font-bold text-gray-900 mb-6 text-center">Wat onze leerlingen zeggen op Google</h3>
        <GoogleReviews />

        <!-- Zie alle reviews -->
        <div class="text-center mt-8">
          <a
            href="https://www.google.com/maps/place/?q=place_id:ChIJ4_e8zzcXcw8RIQCtvKZxLko"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-white px-8 py-4 rounded-lg font-bold hover:opacity-90 transition-all shadow-md"
            style={`background-color: ${secondaryColor}`}
          >
            <Icon name="google" />
            Zie alle reviews op Google
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-12 bg-white border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Ook slagen bij Rij-Vrij?</h3>
        <p class="text-gray-600 mb-6">Plan vandaag je proefles en ontdek hoe snel jij je rijbewijs kunt halen.</p>
        <a
          href="/#proefles-cta"
          class="inline-block text-white px-8 py-4 rounded-lg font-bold hover:opacity-90 transition-all shadow-md"
          style={`background-color: ${primaryColor}`}
        >
          <Icon name="calendar-check" class="mr-2" />
          Plan mijn proefles
        </a>
      </div>
    </section>

  </div>
</Layout>
