---
import Layout from '../layouts/Layout.astro';

const primaryColor = '#0391b0';
const secondaryColor = '#790f34';
import Icon from '../components/Icon.astro';
---

<Layout
  title="Pagina niet gevonden"
  description="De pagina die je zoekt bestaat niet. Ga terug naar de homepage van Rij-Vrij Rijschool."
>
  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="text-center px-4">
      <div class="text-8xl font-bold mb-4" style={`color: ${primaryColor}`}>404</div>
      <h1 class="text-3xl font-bold text-gray-900 mb-4">Pagina niet gevonden</h1>
      <p class="text-gray-600 text-lg mb-8 max-w-md mx-auto">
        De pagina die je zoekt bestaat niet of is verplaatst.
      </p>
      <a
        href="/"
        class="inline-block text-white px-8 py-4 rounded-lg text-lg font-semibold hover:opacity-90 transition-all shadow-lg"
        style={`background-color: ${secondaryColor}`}
      >
        <Icon name="home" class="mr-2" />
        Terug naar home
      </a>
    </div>
  </section>
</Layout>
