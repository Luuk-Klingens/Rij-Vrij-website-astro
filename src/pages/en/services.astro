---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const primaryColor = '#0391b0';
const secondaryColor = '#790f34';

const services = [
  { icon: 'fa-redo', title: 'Refresher driving course', description: 'A complete refresher course to regain confidence behind the wheel. Perfect for people who have not driven for a while.', features: ['60-minute lesson', 'Refresh traffic rules', 'Practical driving skills'] },
  { icon: 'fa-road', title: 'Motorway refresher', description: 'Specifically focused on motorway driving, with attention to joining, leaving and safe overtaking.', features: ['90-minute lesson', 'Motorway techniques', 'Road safety'] },
  { icon: 'fa-parking', title: 'Parking refresher', description: 'Refresher lesson for parking, including parallel parking, right-angle parking and parking in narrow streets.', features: ['60-minute lesson', 'Parking techniques', 'City-specific situations'] },
  { icon: 'fa-user-check', title: 'CBR driving test (elderly)', description: 'Special training for the CBR driving test for elderly drivers, including all required skills and tips.', features: ['90-minute lesson', 'CBR-specific training', 'Exam preparation'] },
  { icon: 'fa-gift', title: 'Give a refresher lesson as a gift', description: 'Give a refresher driving lesson as a gift to someone you care about. A practical and valuable present!', features: ['Gift voucher available', 'Flexible redemption', 'Personal message'] },
  { icon: 'fa-euro-sign', title: 'Pricing', description: 'Transparent and fair prices for all our services. No hidden costs.', features: ['From €74 per lesson', 'Package deals', 'No hidden costs'] },
];
import Icon from '../../components/Icon.astro';
---

<Layout
  title="Services"
  description="View all services from Rij-Vrij Driving School: refresher courses, anxiety driver support, driving skills test and more. Tailored automatic driving lessons in Pijnacker & Delft."
>
  <div class="bg-white">

    <section class="py-20" style={`background: linear-gradient(135deg, ${primaryColor} 0%, ${secondaryColor} 100%)`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Services</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">
          Rij-Vrij offers more than just starter packages. Discover all our services.
        </p>
      </div>
    </section>

    <section class="py-20 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {services.map((service) => (
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100 overflow-hidden flex flex-col">
              <div class="flex items-center justify-center py-7" style={`background-color: ${primaryColor}`}>
                <i class={`fas ${service.icon} text-4xl text-white`}></i>
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <h3 class="font-bold text-gray-900 mb-2 text-center">{service.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed text-center mb-4">{service.description}</p>
                <div class="mt-auto space-y-1">
                  {service.features.map((f) => (
                    <div class="flex items-center gap-2 text-xs text-gray-600">
                      <Icon name="check-circle" class="flex-shrink-0" style={`color: ${primaryColor}`} />
                      {f}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 bg-white border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h3 class="text-xl font-bold text-gray-900 mb-2">Questions about a service?</h3>
        <p class="text-gray-600 text-sm mb-6">Get in touch. We are happy to help.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/en/contact" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
            <Icon name="envelope" class="mr-2" />Get in touch
          </a>
          <a href="/en/#proefles-cta" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${secondaryColor}`}>
            <Icon name="calendar-check" class="mr-2" />Book trial lesson
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>
