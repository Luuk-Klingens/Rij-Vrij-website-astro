---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';

export const prerender = true;

const green        = '#223927';
const gold         = '#ac884d';
const inschrijfUrl = 'https://startmetjerijbewijs.nl/rij-vrij/inschrijven';

const aanpak = [
  { icon: 'user', title: 'You come first', text: 'Your learning style, your safety and your pace determine the rhythm of every lesson.' },
  { icon: 'handshake', title: 'Dedicated instructor', text: 'Always the same familiar instructor for maximum continuity and recognition.' },
  { icon: 'calendar-check', title: 'Clear structure', text: 'Predictable lessons with a fixed build-up; you know exactly what to expect.' },
  { icon: 'shield-alt', title: 'Fewer stimuli', text: 'Extra attention to sensory stimuli and maintaining concentration during the drive.' },
  { icon: 'car', title: 'Always automatic', text: 'No gear changes, complete focus on traffic. That makes a huge difference.' },
  { icon: 'heart', title: 'Patience & understanding', text: 'Never pressure, never rush. Your pace is our pace, always.' },
];

const silvyReview = {
  name: 'Shiyanna Lucifer (Lucy)',
  photo: 'https://lh3.googleusercontent.com/a-/ALV-UjXHdmykFII6CFC4APW09O8hck0gu4kHT0hqYQNenZcnmTQmkxiS=s128-c0x00000000-cc-rp-mo',
  text: "Wonderful driving school! Peter is very calm, patient and above all honest! I also had great conversations with him about all sorts of things. There was a relaxed atmosphere in the car and everything was open for discussion. This greatly boosted my confidence behind the wheel. This was with the added challenge of my ADHD, but Peter handled it brilliantly. He could read me like a book and scheduled a break before I even realised I needed one. Thank you so much Peter!",
  date: '6 months ago',
};
---

<Layout
  title="Refresher Lessons with Autism & ADHD"
  description="Rij-Vrij specialises in refresher lessons for people with autism or ADHD. Patience, clear structure and adaptation to your pace. Certified with rijles-en-autisme.nl. Pijnacker, Haaglanden region."
>

  <!-- ═══ HERO ═══ -->
  <section style={`background-color: ${green}`} class="py-20">
    <div class="section-container">
      <div style={`width: 2.5rem; height: 4px; background-color: ${gold}; margin-bottom: 1.5rem`}></div>
      <p class="text-xs font-bold tracking-widest uppercase mb-3" style={`color: ${gold}`}>Certified specialist</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4" style="line-height: 1.1">
        Autism &amp; ADHD
      </h1>
      <p class="text-lg max-w-2xl mb-8" style="color: rgba(255,255,255,0.70)">
        Refresher lessons your way. Rij-Vrij guides people with autism or ADHD with knowledge, patience and a clear structure.
      </p>
      <div class="inline-flex items-center gap-3 px-5 py-3 text-sm font-bold text-white" style={`background-color: rgba(172,136,77,0.15); border-left: 3px solid ${gold}; border-radius: 0 4px 4px 0`}>
        <Icon name="certificate" style={`color: ${gold}; font-size:14px`} />
        Registered with rijles-en-autisme.nl, part of Spectrum Brabant
      </div>
    </div>
  </section>

  <!-- Diagonal transition -->
  <div style={`background-color: ${green}; overflow: hidden; height: 3rem`}>
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
      <path d="M0,0 L1440,48 L0,48 Z" fill="white" />
    </svg>
  </div>

  <!-- ═══ INFO + REVIEW ═══ -->
  <section class="pt-4 pb-20 bg-white">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Info text -->
        <div>
          <span class="gold-bar"></span>
          <div class="space-y-4 text-base leading-relaxed" style="color: #374151">
            <p>
              People with autism (ASD), ADHD or similar characteristics can drive perfectly well and take refresher lessons. Because their brains sometimes process information differently, guidance may need to be a little different — and that is exactly what we specialise in.
            </p>
            <p>
              Rij-Vrij is a certified specialist and is registered with <a href="https://www.rijles-en-autisme.nl" target="_blank" rel="noopener noreferrer" class="font-bold hover:opacity-70 transition-opacity" style={`color: ${green}`}>rijles-en-autisme.nl</a>, part of Spectrum Brabant, a centre for care and education specialising in autism and ADHD.
            </p>
            <p>
              Driving in an automatic car helps extra: no gear changes, complete focus on traffic. That brings calm, clarity and fewer stimuli.
            </p>
            <p class="font-bold" style={`color: ${green}`}>
              Always at your pace. Never pressure, never rush.
            </p>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4 mt-8">
            <div class="p-5 text-center" style={`border: 2px solid #e4ddd0; border-top: 4px solid ${gold}; border-radius: 4px`}>
              <div class="text-3xl font-extrabold mb-1" style={`color: ${green}`}>100%</div>
              <div class="text-sm" style="color: #5c5c50">Automatic, less distraction</div>
            </div>
            <div class="p-5 text-center" style={`border: 2px solid #e4ddd0; border-top: 4px solid ${gold}; border-radius: 4px`}>
              <div class="text-3xl font-extrabold mb-1" style={`color: ${green}`}>Certified</div>
              <div class="text-sm" style="color: #5c5c50">Rijles-en-autisme.nl</div>
            </div>
          </div>
        </div>

        <!-- Review -->
        <div style={`border: 2px solid #e4ddd0; border-left: 4px solid ${gold}; border-radius: 0 4px 4px 0; background: #faf8f4; padding: 2rem`}>
          <p class="text-xs font-bold uppercase tracking-widest mb-5" style={`color: ${gold}`}>What a student said about us</p>

          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <Icon name="star" class="text-yellow-400 text-lg" />
            ))}
          </div>

          <p class="text-sm leading-relaxed italic mb-6" style="color: #374151">
            "{silvyReview.text}"
          </p>

          <div class="flex items-center gap-3 border-t pt-5" style="border-color: #e4ddd0">
            <img
              src={silvyReview.photo}
              alt={silvyReview.name}
              width="44" height="44" loading="lazy"
              style="width:44px;height:44px;border-radius:2px;object-fit:cover;flex-shrink:0"
            />
            <div>
              <p class="font-bold text-sm" style={`color: ${green}`}>{silvyReview.name}</p>
              <p class="text-xs" style="color: #5c5c50">{silvyReview.date} · Google Review</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ OUR APPROACH ═══ -->
  <section class="py-20" style="background-color: #faf8f4">
    <div class="section-container">

      <div class="mb-12 text-center">
        <span class="gold-bar-center"></span>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style={`color: ${green}`}>Our approach</h2>
        <p class="max-w-xl mx-auto" style="color: #5c5c50">
          Every lesson is tailored to your needs. This is what a refresher lesson at Rij-Vrij looks like for you.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {aanpak.map((item) => (
          <div class="card-dutch flex flex-col gap-4">
            <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
              <Icon name={item.icon} class="text-white" style="font-size:16px" />
            </div>
            <div>
              <h3 class="font-extrabold mb-2" style={`color: ${green}`}>{item.title}</h3>
              <p class="text-sm leading-relaxed" style="color: #5c5c50">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 bg-white border-t" style="border-color: #e4ddd0">
    <div class="section-container text-center">
      <span class="gold-bar-center"></span>
      <h3 class="text-2xl font-extrabold mb-3" style={`color: ${green}`}>Ready to get started?</h3>
      <p class="mb-7" style="color: #5c5c50">
        Plan a refresher lesson or ask your question. We are happy to help you on your way, at your pace.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href={inschrijfUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
          <Icon name="calendar-check" style="font-size:13px" />
          Plan refresher lesson
        </a>
        <a href="/en/contact" class="btn-outline">
          <Icon name="envelope" style="font-size:13px" />
          Get in touch
        </a>
      </div>
    </div>
  </section>

</Layout>
