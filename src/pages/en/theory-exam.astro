---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const primaryColor = '#223927';
const secondaryColor = '#ac884d';

const leeftijden = [
  { leeftijd: 'From age 16', tekst: 'Sit the theory exam' },
  { leeftijd: 'From age 16½', tekst: 'Start driving lessons' },
  { leeftijd: 'From age 17', tekst: 'Practical exam (2toDrive)' },
  { leeftijd: 'From age 18', tekst: 'Drive independently' },
];

const tips = [
  { icon: 'fa-mobile-alt', text: 'Use the On My Way app daily, even just 15 minutes makes a difference' },
  { icon: 'fa-clipboard-check', text: 'Do as many practice exams as possible before taking the real thing' },
  { icon: 'fa-exclamation-triangle', text: 'Pay close attention to hazard perception, many people fail on this' },
  { icon: 'fa-calendar-check', text: 'Only book your exam when you consistently pass the practice exams' },
];

const inhoud = ['Traffic rules', 'Road signs', 'Hazard perception', 'Driving conditions'];
import Icon from '../../components/Icon.astro';
---

<Layout
  title="Theory Exam"
  description="Everything about the CBR theory exam for your driving licence. Tips, what to expect, and how the On My Way app helps you prepare. Available in English."
>
  <div class="bg-white">

    <section class="py-20" style={`background: linear-gradient(135deg, ${primaryColor} 0%, ${secondaryColor} 100%)`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-white text-sm font-semibold uppercase tracking-widest mb-3">Step 1 towards your licence</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Theory Exam</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">
          Before you can sit your practical exam, you must first pass the theory exam at the CBR.
        </p>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">When can you do what?</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {leeftijden.map((item) => (
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100 overflow-hidden flex flex-col">
              <div class="flex items-center justify-center py-6" style={`background-color: ${primaryColor}`}>
                <Icon name="birthday-cake" class="text-4xl text-white" />
              </div>
              <div class="p-5 flex flex-col flex-grow text-center">
                <p class="font-bold text-gray-900 text-sm mb-1">{item.leeftijd}</p>
                <p class="text-gray-600 text-xs">{item.tekst}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
              <span class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}`}>
                <Icon name="book" class="text-white text-sm" />
              </span>
              What is in the exam?
            </h2>
            <div class="space-y-3">
              {inhoud.map((item) => (
                <div class="flex items-center gap-3 p-4 bg-gray-50 rounded-xl border border-gray-100">
                  <Icon name="check-circle" class="flex-shrink-0" style={`color: ${primaryColor}`} />
                  <span class="text-gray-700 font-medium">{item}</span>
                </div>
              ))}
            </div>
            <div class="mt-6 rounded-xl p-5 flex items-start gap-4" style={`background: ${primaryColor}10`}>
              <Icon name="gift" class="mt-0.5 flex-shrink-0" style={`color: ${primaryColor}`} />
              <p class="text-gray-700 text-sm leading-relaxed">
                Via the <strong>On My Way app</strong> you practise with 50 complete practice exams. The app is also available in <strong>English</strong>. Included free with every Rij-Vrij package.
              </p>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
              <span class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background-color: ${secondaryColor}`}>
                <Icon name="lightbulb" class="text-white text-sm" />
              </span>
              Preparation tips
            </h2>
            <ul class="space-y-3">
              {tips.map((tip) => (
                <li class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}15`}>
                    <i class={`fas ${tip.icon} text-sm`} style={`color: ${primaryColor}`}></i>
                  </div>
                  <span class="text-gray-700 text-sm leading-relaxed pt-1">{tip.text}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="py-10 bg-gray-50 border-y border-gray-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex items-start gap-4">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style={`background-color: ${secondaryColor}15`}>
          <Icon name="flag-checkered" style={`color: ${secondaryColor}`} />
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">Passed your theory? What next?</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Once you have passed your theory, you can request an interim test (TTT) and ultimately the practical exam. Your instructor will help you with this.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Start learning right away?</h3>
        <p class="text-gray-600 mb-6">Book a trial lesson and receive free access to the On My Way app.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/en/#proefles-cta" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
            <Icon name="calendar-check" class="mr-2" />Book free trial lesson
          </a>
          <a href="/en/onmyway" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${secondaryColor}`}>
            <Icon name="mobile-alt" class="mr-2" />About the app
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>
