---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;
---

<Layout
  title="Privacy Policy"
  description="Privacy policy of Rij-Vrij Driving School. How we handle your personal data."
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">Privacy Policy — Rij-Vrij Driving School</h1>

    <p class="text-gray-600 mb-4 p-4 bg-amber-50 border border-amber-100 rounded-xl">
      <strong>Note:</strong> The privacy policy was drawn up in Dutch and the Dutch version is legally binding. The English translation below is provided for information purposes only.
    </p>

    <p class="text-gray-600 mb-10">Rij-Vrij Driving School, based in Pijnacker, is responsible for the processing of personal data as described in this privacy policy.</p>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Contact details</h2>
      <p class="text-gray-600">Rij-Vrij Driving School<br />Hankweg 39, 2641 WV Pijnacker<br />015-2224012<br />info@Rij-Vrij.com</p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Personal data we process</h2>
      <p class="text-gray-600 mb-3">Rij-Vrij processes your personal data because you use our services and/or because you provide this data yourself. Below is an overview of the personal data we process:</p>
      <ul class="text-gray-600 space-y-1 list-disc list-inside">
        <li>First and last name</li>
        <li>Address details</li>
        <li>Telephone number</li>
        <li>Email address</li>
        <li>Date of birth</li>
        <li>IP address</li>
        <li>Other personal data that you actively provide</li>
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Purpose of processing</h2>
      <p class="text-gray-600">Rij-Vrij processes your personal data for the following purposes:</p>
      <ul class="text-gray-600 space-y-1 list-disc list-inside mt-2">
        <li>Handling your registration and lesson agreements</li>
        <li>Sending our newsletter and/or advertising brochure</li>
        <li>Calling or emailing you when necessary to provide our services</li>
        <li>Informing you of changes to our services and products</li>
        <li>Delivering goods and services to you</li>
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Retention period</h2>
      <p class="text-gray-600">Rij-Vrij does not retain your personal data longer than strictly necessary for the purposes for which your data is collected.</p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Your rights</h2>
      <p class="text-gray-600 mb-2">You have the right to view, correct or delete your personal data. You also have the right to withdraw your consent to data processing or to object to the processing. You have the right to data portability.</p>
      <p class="text-gray-600">To exercise these rights, please contact us at info@Rij-Vrij.com. We will respond within four weeks.</p>
    </section>

    <div class="mt-8 p-5 bg-gray-50 border border-gray-200 rounded-xl">
      <p class="text-gray-600 text-sm">For the complete and legally binding privacy policy (in Dutch), please <a href="/privacy-voorwaarden" class="text-blue-600 hover:underline">click here</a> or contact us at <a href="mailto:info@Rij-Vrij.com" class="text-blue-600 hover:underline">info@Rij-Vrij.com</a>.</p>
    </div>
  </div>
</Layout>
