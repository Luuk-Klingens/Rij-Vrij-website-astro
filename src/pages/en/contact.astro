---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';

export const prerender = true;

const green        = '#223927';
const gold         = '#ac884d';
const inschrijfUrl = 'https://startmetjerijbewijs.nl/rij-vrij/inschrijven';
---

<Layout
  title="Contact | Rij-Vrij Refresher Lessons"
  description="Contact Rij-Vrij. Call 015-2224012 or email info@rij-vrij.nl. Based in Pijnacker. Book your refresher lesson directly."
>

  <!-- ═══ HERO ═══ -->
  <section style={`background-color: ${green}`} class="py-20">
    <div class="section-container">
      <div style={`width: 2.5rem; height: 4px; background-color: ${gold}; margin-bottom: 1.5rem`}></div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4" style="line-height: 1.1">Contact</h1>
      <p class="text-lg max-w-xl" style="color: rgba(255,255,255,0.70)">
        Questions about our refresher lessons? Or want to plan a lesson directly? Get in touch, we respond quickly.
      </p>
    </div>
  </section>

  <!-- Diagonal transition -->
  <div style={`background-color: ${green}; overflow: hidden; height: 3rem`}>
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
      <path d="M0,0 L1440,48 L0,48 Z" fill="white" />
    </svg>
  </div>

  <!-- ═══ CONTACT CONTENT ═══ -->
  <section class="pt-4 pb-20 bg-white">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Contact info -->
        <div>
          <span class="gold-bar"></span>
          <h2 class="text-2xl font-extrabold mb-8" style={`color: ${green}`}>Contact details</h2>

          <div class="space-y-5">
            {[
              { icon: 'phone', label: 'Phone', value: '015-2224012', href: 'tel:0152224012' },
              { icon: 'envelope', label: 'Email', value: 'info@rij-vrij.nl', href: 'mailto:info@rij-vrij.nl' },
            ].map((item) => (
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
                  <Icon name={item.icon} class="text-white" style="font-size:14px" />
                </div>
                <div>
                  <p class="font-bold text-sm" style={`color: ${green}`}>{item.label}</p>
                  <a href={item.href} class="text-sm transition-opacity hover:opacity-70" style="color: #374151">{item.value}</a>
                </div>
              </div>
            ))}

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
                <Icon name="map-marker-alt" class="text-white" style="font-size:14px" />
              </div>
              <div>
                <p class="font-bold text-sm" style={`color: ${green}`}>Address</p>
                <p class="text-sm" style="color: #374151">Hankweg 39, 2641 WV Pijnacker</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
                <Icon name="clock" class="text-white" style="font-size:14px" />
              </div>
              <div>
                <p class="font-bold text-sm mb-2" style={`color: ${green}`}>Opening hours</p>
                {[
                  'Monday – Friday: 08:00 – 17:00',
                  'Saturday: By appointment',
                  'Sunday: Closed',
                ].map((t) => (
                  <p class="text-sm" style="color: #374151">{t}</p>
                ))}
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
                <Icon name="map" class="text-white" style="font-size:14px" />
              </div>
              <div>
                <p class="font-bold text-sm" style={`color: ${green}`}>Lesson area</p>
                <p class="text-sm" style="color: #374151">Delft, Pijnacker, Zoetermeer, Rijswijk and 11 other municipalities</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact options -->
        <div>
          <span class="gold-bar"></span>
          <h2 class="text-2xl font-extrabold mb-6" style={`color: ${green}`}>Get in touch</h2>
          <p class="text-sm mb-8" style="color: #5c5c50">
            We respond to your message as quickly as possible. Prefer email? Include your name and phone number and we will call you back.
          </p>

          <div class="space-y-4">
            <a
              href="mailto:info@rij-vrij.nl?subject=Question%20via%20website"
              class="flex items-center gap-4 p-5 group transition-all"
              style={`border: 2px solid #e4ddd0; border-left: 4px solid ${gold}; border-radius: 0 4px 4px 0; background: #faf8f4`}
            >
              <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
                <Icon name="envelope" class="text-white text-lg" />
              </div>
              <div class="flex-grow">
                <p class="font-bold text-sm" style={`color: ${green}`}>Send an email</p>
                <p class="text-sm" style="color: #5c5c50">info@rij-vrij.nl</p>
              </div>
              <Icon name="arrow-right" style="color: #ac884d; font-size: 14px" />
            </a>

            <a
              href="tel:0152224012"
              class="flex items-center gap-4 p-5 group transition-all"
              style={`border: 2px solid #e4ddd0; border-left: 4px solid ${gold}; border-radius: 0 4px 4px 0; background: #faf8f4`}
            >
              <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
                <Icon name="phone" class="text-white text-lg" />
              </div>
              <div class="flex-grow">
                <p class="font-bold text-sm" style={`color: ${green}`}>Call us</p>
                <p class="text-sm" style="color: #5c5c50">015-2224012</p>
              </div>
              <Icon name="arrow-right" style="color: #ac884d; font-size: 14px" />
            </a>

            <a
              href={inschrijfUrl} target="_blank" rel="noopener noreferrer"
              class="btn-primary w-full justify-center text-center py-4"
            >
              <Icon name="calendar-check" style="font-size:13px" />
              Plan my refresher lesson
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
