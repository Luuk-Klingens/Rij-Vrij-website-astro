---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const primaryColor = '#223927';
const secondaryColor = '#ac884d';
import Icon from '../../components/Icon.astro';
---

<Layout
  title="Contact"
  description="Contact Rij-Vrij Driving School. Call 015-2224012 or email info@rij-vrij.nl. Based at Hankweg 39 in Pijnacker. Book your trial lesson directly."
>
  <div class="bg-white">

    <section class="py-16" style={`background-color: ${primaryColor}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contact</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">Get in touch for more information or to book a trial lesson.</p>
      </div>
    </section>

    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

          <div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-8">Contact Information</h2>
            <div class="space-y-5">
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="phone" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Phone</h4>
                  <a href="tel:0152224012" class="hover:underline" style={`color: ${primaryColor}`}>015-2224012</a>
                </div>
              </div>
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="envelope" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Email</h4>
                  <a href="mailto:info@rij-vrij.nl" class="hover:underline" style={`color: ${primaryColor}`}>info@rij-vrij.nl</a>
                </div>
              </div>
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="map-marker-alt" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Address</h4>
                  <p class="text-gray-600">Hankweg 39, 2641 WV Pijnacker</p>
                </div>
              </div>
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="clock" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Opening hours</h4>
                  <p class="text-gray-600 text-sm">Monday: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Tuesday: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Wednesday: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Thursday: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Friday: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Saturday: By appointment</p>
                  <p class="text-gray-600 text-sm">Sunday: Closed</p>
                </div>
              </div>
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="map" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Lesson area</h4>
                  <p class="text-gray-600 text-sm">Delft, Pijnacker, Zoetermeer, Rijswijk and 8 other municipalities</p>
                </div>
              </div>
            </div>
          </div>

          <div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-8">Get in touch</h2>
            <p class="text-gray-600 mb-8 leading-relaxed">
              Contact us directly via one of the options below. We will respond to your message as soon as possible.
            </p>
            <div class="space-y-4">
              <a href="mailto:info@rij-vrij.nl?subject=Question%20via%20website" class="flex items-center gap-4 p-5 rounded-xl border-2 hover:shadow-md transition-all group" style={`border-color: ${primaryColor}`}>
                <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="envelope" class="text-white text-lg" />
                </div>
                <div>
                  <p class="font-bold text-gray-900">Send an email</p>
                  <p class="text-sm" style={`color: ${primaryColor}`}>info@rij-vrij.nl</p>
                </div>
                <Icon name="arrow-right" class="ml-auto text-gray-600 transition-colors" />
              </a>
              <a href="tel:0152224012" class="flex items-center gap-4 p-5 rounded-xl border-2 hover:shadow-md transition-all group" style={`border-color: ${primaryColor}`}>
                <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="phone" class="text-white text-lg" />
                </div>
                <div>
                  <p class="font-bold text-gray-900">Call us</p>
                  <p class="text-sm" style={`color: ${primaryColor}`}>015-2224012</p>
                </div>
                <Icon name="arrow-right" class="ml-auto text-gray-600 transition-colors" />
              </a>
              <a href="mailto:info@rij-vrij.nl?subject=Trial%20lesson%20request" class="flex items-center justify-center gap-3 p-5 rounded-xl text-white font-bold text-lg hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
                <Icon name="calendar-check" />
                Book my trial lesson
              </a>
            </div>
            <p class="text-sm text-gray-600 mt-6">
              Prefer email? Include your name, phone number and city in your message and we will contact you as soon as possible.
            </p>
          </div>

        </div>
      </div>
    </section>

  </div>
</Layout>
