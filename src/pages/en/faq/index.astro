---
import Layout from '../../../layouts/Layout.astro';
import { faqCategoriesEN } from '../../../data/faq';

export const prerender = true;

const primaryColor = '#223927';
const secondaryColor = '#ac884d';
import Icon from '../../../components/Icon.astro';
---

<Layout
  title="Frequently Asked Questions"
  description="Answers to frequently asked questions about automatic driving lessons at Rij-Vrij Driving School. About lessons, packages, trial lesson, exam, autism & ADHD and more."
>
  <div class="bg-white">

    <section class="py-20" style={`background: linear-gradient(135deg, ${primaryColor} 0%, ${secondaryColor} 100%)`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-white text-sm font-semibold uppercase tracking-widest mb-3">Answers to your questions</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Frequently Asked Questions</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">
          Everything about driving lessons at Rij-Vrij. Can't find your question? Feel free to contact us.
        </p>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
        {faqCategoriesEN.map((cat) => (
          <div>
            <div class="flex items-center gap-3 mb-5">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}`}>
                <i class={`fas ${cat.icon} text-sm text-white`}></i>
              </div>
              <h2 class="text-xl font-bold text-gray-900">{cat.categorie}</h2>
            </div>
            <div class="space-y-2">
              {cat.items.map((item) => (
                <a
                  href={`/en/faq/${item.slug}/`}
                  class="flex items-center justify-between p-5 bg-white border border-gray-100 rounded-xl hover:border-blue-200 hover:shadow-sm transition-all group"
                >
                  <span class="font-medium text-gray-900 group-hover:text-blue-600 transition-colors pr-4">{item.vraagEN}</span>
                  <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 transition-all group-hover:bg-blue-50" style={`background-color: ${primaryColor}15`}>
                    <Icon name="chevron-right" class="text-xs" style={`color: ${primaryColor}`} />
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="py-12 bg-gray-50 border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style={`background-color: ${primaryColor}15`}>
          <Icon name="question" class="text-xl" style={`color: ${primaryColor}`} />
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Can't find your question?</h3>
        <p class="text-gray-600 text-sm mb-6">Get in touch. We are happy to answer your question personally.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/en/contact" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
            <Icon name="envelope" class="mr-2" />Ask your question
          </a>
          <a href="/en/#proefles-cta" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${secondaryColor}`}>
            <Icon name="calendar-check" class="mr-2" />Book a trial lesson
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>
