---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const primaryColor = '#223927';
const secondaryColor = '#ac884d';

const startPakketten = [
  {
    name: 'Start10',
    description: '10 lessons of 90 minutes',
    price: '1.399',
    isPopular: false,
    features: ['10 driving lessons of 90 minutes', 'CBR practical exam included', 'Fixed driving instructor', 'Free trial lesson (worth €49)', 'Free theory training (worth €59)', 'Package saving of €124', 'Start immediately!'],
    termijn: null,
  },
  {
    name: 'Populair20',
    description: '20 lessons of 90 minutes',
    price: '2.399',
    isPopular: true,
    features: ['20 driving lessons of 90 minutes', 'CBR practical exam included', 'Fixed driving instructor', 'Free trial lesson (worth €49)', 'Free theory training (worth €59)', 'Pay in two free instalments', 'Package saving of €214', 'Start immediately!'],
    termijn: '2 instalments',
  },
  {
    name: 'Compleet30',
    description: '30 lessons of 90 minutes',
    price: '3.299',
    isPopular: false,
    features: ['30 driving lessons of 90 minutes', 'CBR practical exam included', 'Fixed driving instructor', 'Free trial lesson (worth €49)', 'Free theory training (worth €59)', 'Pay in three free instalments', 'Package saving of €404', 'Start immediately!'],
    termijn: '3 instalments',
  },
];

const vervolgPakketten = [
  { name: 'Verder 10', description: '10 lessons of 90 minutes', price: '1.299', features: ['10 driving lessons of 90 minutes', 'CBR practical exam included', 'Package saving of €116'] },
  { name: 'Verder 15', description: '15 lessons of 90 minutes', price: '1.799', features: ['15 driving lessons of 90 minutes', 'CBR practical exam included', 'Package saving of €161'] },
  { name: 'Verder 20', description: '20 lessons of 90 minutes', price: '2.299', features: ['20 driving lessons of 90 minutes', 'CBR practical exam included', 'Package saving of €206'] },
];

const tariefSections = [
  {
    title: 'Individual lessons',
    items: [
      { naam: 'Trial lesson of 60 minutes', prijs: '€ 49.00', note: '* Free with starter packages!' },
      { naam: 'Driving lesson of 90 minutes', prijs: '€ 109.00', note: '' },
    ],
  },
  {
    title: 'Theory study materials',
    items: [
      { naam: 'Theory via On My Way app', prijs: '€ 59.00', note: '' },
    ],
  },
  {
    title: 'Exam fees',
    items: [
      { naam: 'Practical exam (CBR) incl. car use', prijs: '€ 325.00', note: '' },
      { naam: 'Interim test (CBR) incl. car use', prijs: '€ 275.00', note: '' },
      { naam: 'Exam anxiety practical exam (CBR) incl. car use', prijs: '€ 395.00', note: '' },
      { naam: 'BNOR practical exam (CBR) incl. car use', prijs: '€ 360.00', note: '' },
    ],
  },
];
import Icon from '../../components/Icon.astro';
---

<Layout
  title="Prices & Driving Packages"
  description="View the prices and driving packages of Rij-Vrij Driving School. Starter package from €1,399 including free trial lesson and On My Way app. Transparent pricing, no hidden costs."
>
  <div class="bg-white">

    <section class="py-16" style={`background-color: ${primaryColor}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Prices</h1>
        <p class="text-xl text-white max-w-3xl mx-auto">Overview of our prices as of 1 January 2026.</p>
      </div>
    </section>

    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Starter packages</h2>
          <p class="text-gray-600">Begin your lessons, including trial lesson, theory & CBR exam.</p>
        </div>
        <div class="flex flex-wrap justify-center gap-6">
          {startPakketten.map((pkg) => (
            <div
              class={`bg-white rounded-xl border-2 p-6 flex flex-col relative w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] max-w-sm ${pkg.isPopular ? 'shadow-xl' : 'border-gray-200 shadow-sm'}`}
              style={pkg.isPopular ? `border-color: ${primaryColor}` : ''}
            >
              {pkg.isPopular && (
                <div class="text-center mb-4">
                  <span class="text-white px-4 py-1 rounded-full text-xs font-semibold" style={`background-color: ${primaryColor}`}>Most popular</span>
                </div>
              )}
              <h3 class="text-xl font-bold text-gray-900 mb-1 text-center">{pkg.name}</h3>
              <p class="text-gray-600 text-xs text-center mb-4">{pkg.description}</p>
              <div class="text-3xl font-bold mb-1 text-center" style={`color: ${primaryColor}`}>€ {pkg.price},-</div>
              {pkg.termijn && (
                <p class="text-xs text-center text-gray-500 mb-2">Payment in {pkg.termijn} available</p>
              )}
              <div class="flex-grow space-y-2 mb-6 mt-4">
                {pkg.features.map((feature) => (
                  <div class="flex items-start text-sm text-gray-700">
                    <Icon name="check-circle" class="mr-2 mt-0.5 flex-shrink-0" style={`color: ${primaryColor}`} />
                    <span>{feature}</span>
                  </div>
                ))}
              </div>
              <a href="/en/#proefles-cta" class="text-white px-4 py-3 rounded-lg text-center font-semibold hover:opacity-90 transition-colors block w-full" style={`background-color: ${pkg.isPopular ? primaryColor : secondaryColor}`}>
                Sign up now!
              </a>
            </div>
          ))}
        </div>

        <div class="mt-8 max-w-2xl mx-auto flex items-start gap-3 bg-blue-100 border border-blue-300 rounded-xl px-5 py-4 text-sm text-blue-900">
          <Icon name="info-circle" class="mt-0.5 text-blue-600 flex-shrink-0" />
          <p>
            <strong>Please note:</strong> all starter packages exclude the health declaration (€ 45.25), which you complete yourself at <a href="https://mijn.cbr.nl" target="_blank" rel="noopener noreferrer" class="underline hover:text-blue-700">mijn.cbr.nl</a>.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white border-t border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Follow-up packages</h2>
          <p class="text-gray-600">Already had lessons elsewhere? Continue with a follow-up package.</p>
        </div>
        <div class="flex flex-wrap justify-center gap-6">
          {vervolgPakketten.map((pkg) => (
            <div class="bg-white rounded-xl border-2 border-gray-200 shadow-sm p-6 flex flex-col w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)] max-w-sm">
              <h3 class="text-xl font-bold text-gray-900 mb-1 text-center">{pkg.name}</h3>
              <p class="text-gray-600 text-xs text-center mb-4">{pkg.description}</p>
              <div class="text-3xl font-bold mb-4 text-center" style={`color: ${primaryColor}`}>€ {pkg.price},-</div>
              <div class="flex-grow space-y-2 mb-6">
                {pkg.features.map((feature) => (
                  <div class="flex items-start text-sm text-gray-700">
                    <Icon name="check-circle" class="mr-2 mt-0.5 flex-shrink-0" style={`color: ${primaryColor}`} />
                    <span>{feature}</span>
                  </div>
                ))}
              </div>
              <a href="/en/contact" class="text-white px-4 py-3 rounded-lg text-center font-semibold hover:opacity-90 transition-colors block w-full" style={`background-color: ${secondaryColor}`}>
                Get in touch
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-gray-50 border-t border-gray-100">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 space-y-10">
        {tariefSections.map((section) => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">{section.title}</h3>
            <div class="space-y-4">
              {section.items.map((item) => (
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3 border-b border-gray-100 pb-4 last:border-b-0 last:pb-0">
                  <div class="max-w-3xl">
                    <p class="font-semibold text-gray-900">{item.naam}</p>
                    {item.note && <p class="text-sm text-gray-600 mt-1">{item.note}</p>}
                  </div>
                  <div class="text-lg font-bold whitespace-nowrap" style={`color: ${primaryColor}`}>{item.prijs}</div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="py-12 bg-gray-50 border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Ready to start?</h3>
        <p class="text-gray-600 mb-6">Book your trial lesson today and discover how quickly you can get your licence with an automatic car.</p>
        <a href="/en/#proefles-cta" class="inline-block text-white px-8 py-4 rounded-lg font-bold hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
          <Icon name="calendar-check" class="mr-2" />Book my trial lesson
        </a>
      </div>
    </section>

  </div>
</Layout>
