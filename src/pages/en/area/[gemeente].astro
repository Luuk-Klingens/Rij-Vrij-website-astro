---
import Layout from '../../../layouts/Layout.astro';
import lesgebieden from '../../../data/lesgebieden';

export const prerender = true;

export function getStaticPaths() {
  return lesgebieden.map((g) => ({
    params: { gemeente: g.slug },
    props: { lesgebied: g },
  }));
}

const { lesgebied } = Astro.props;

const primaryColor = '#223927';
const secondaryColor = '#ac884d';
import Icon from '../../../components/Icon.astro';
---

<Layout
  title={`Automatic driving lessons in ${lesgebied.naam}`}
  description={`Automatic driving lessons in ${lesgebied.naam} with Rij-Vrij Driving School. High pass rate, no waiting times. Autism & ADHD specialist. Book your free trial lesson.`}
>
  <div class="bg-white">

    <section class="py-20" style={`background-color: ${primaryColor}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <nav class="text-white text-sm mb-6" aria-label="Breadcrumb">
          <a href="/en/" class="hover:text-white transition-colors">Home</a>
          <span class="mx-2">/</span>
          <a href="/en/areas" class="hover:text-white transition-colors">Areas</a>
          <span class="mx-2">/</span>
          <span class="text-white font-medium">{lesgebied.naam}</span>
        </nav>
        <p class="text-white text-sm font-semibold uppercase tracking-widest mb-3">Lessons in your area</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
          Automatic driving lessons in {lesgebied.naam}
        </h1>
        <p class="text-xl text-white max-w-2xl mx-auto">{lesgebied.intro}</p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/en/#proefles-cta" class="inline-block text-white px-8 py-4 rounded-lg font-semibold hover:opacity-90 transition-all shadow-lg" style={`background-color: ${secondaryColor}`}>
            <Icon name="calendar-check" class="mr-2" />Book my trial lesson
          </a>
          <a href="tel:0152224012" class="inline-block bg-white/20 backdrop-blur-sm border border-white/40 text-white px-8 py-4 rounded-lg font-semibold hover:bg-white/30 transition-all">
            <Icon name="phone" class="mr-2" />015-2224012
          </a>
        </div>
      </div>
    </section>

    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Why Rij-Vrij in {lesgebied.naam}?</h2>
          <p class="text-gray-600">Discover what driving lessons with Rij-Vrij offer you in {lesgebied.naam}.</p>
        </div>
        <ul class="space-y-4">
          {lesgebied.highlights.map((punt) => (
            <li class="flex items-start gap-4 p-5 rounded-xl border border-gray-100 bg-gray-50">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style={`background-color: ${primaryColor}`}>
                <Icon name="check" class="text-white text-sm" />
              </div>
              <p class="text-gray-800 font-medium">{punt}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-3">Exam locations from {lesgebied.naam}</h2>
        <p class="text-gray-600 mb-8 text-sm">From {lesgebied.naam} you sit your exam at one of these CBR locations. We drive you there.</p>
        <div class={`grid gap-6 ${lesgebied.examen.length === 1 ? 'grid-cols-1 max-w-xs mx-auto' : 'grid-cols-1 sm:grid-cols-2'}`}>
          {lesgebied.examen.map((stad) => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style={`background-color: ${secondaryColor}15`}>
                <Icon name="flag-checkered" class="text-xl" style={`color: ${secondaryColor}`} />
              </div>
              <h3 class="text-lg font-bold text-gray-900">CBR {stad}</h3>
              <p class="text-gray-600 text-sm mt-1">South Holland</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {lesgebied.buurtwijken.length > 0 && (
      <section class="py-12 bg-white border-t border-gray-100">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <h2 class="text-xl font-bold text-gray-900 mb-4">Lessons throughout {lesgebied.naam}</h2>
          <p class="text-gray-600 text-sm mb-6">We teach throughout all neighbourhoods of {lesgebied.naam}, including:</p>
          <div class="flex flex-wrap justify-center gap-3">
            {lesgebied.buurtwijken.map((wijk) => (
              <span class="px-4 py-2 rounded-full text-sm font-medium text-white" style={`background-color: ${primaryColor}`}>{wijk}</span>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="py-16 bg-gray-50 border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h2 class="text-2xl font-bold text-gray-900 mb-3">Ready to start in {lesgebied.naam}?</h2>
        <p class="text-gray-600 mb-8">Choose a driving package or first book a no-obligation trial lesson.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/en/prices" class="inline-block text-white px-8 py-4 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
            <Icon name="tags" class="mr-2" />View packages
          </a>
          <a href="/en/contact" class="inline-block text-white px-8 py-4 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${secondaryColor}`}>
            <Icon name="envelope" class="mr-2" />Get in touch
          </a>
        </div>
      </div>
    </section>

    <section class="py-12 bg-white border-t border-gray-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-gray-600 text-sm mb-4">Rij-Vrij also teaches in other municipalities</p>
        <a href="/en/areas" class="text-sm font-semibold hover:underline" style={`color: ${primaryColor}`}>
          <Icon name="map" class="mr-1" />View all areas
        </a>
      </div>
    </section>

  </div>
</Layout>
