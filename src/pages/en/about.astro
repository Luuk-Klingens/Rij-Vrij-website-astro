---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const primaryColor = '#223927';
const secondaryColor = '#ac884d';

const bio = [
  'Driving instructor and owner of Rij-Vrij Driving School. In the past I gained extensive experience in teaching, coaching and guiding people in another sector (financial services). Since 2024 I have been active full-time in the driving school industry, and in January 2025 I founded my own driving school.',
  'Driving is my passion, and nothing is more rewarding than sharing that passion with others.',
  'At Rij-Vrij, you come first! Your learning style, your safety and your pace set the rhythm. Whether you are sitting behind the wheel for the very first time or have had lessons before, together we will make sure you take to the road safely and confidently.',
  'So if you are ready to take the first step towards your driving licence — in a relaxed, fun and educational way — you have come to the right place.',
  'Feel free to get in touch for more information or to book a trial lesson.',
];

const waarden = [
  { icon: 'fa-user', title: 'Your pace', text: 'Your learning style and your pace set the rhythm of the lessons. No pressure, no rush.' },
  { icon: 'fa-shield-alt', title: 'Your safety', text: 'Safety always comes first. We make sure you take to the road with full confidence.' },
  { icon: 'fa-heart', title: 'Your enjoyment', text: 'Lessons at Rij-Vrij are relaxed, fun and educational. Together we make it a positive experience.' },
];
import Icon from '../../components/Icon.astro';
---

<Layout
  title="About Us"
  description="Meet Peter, driving instructor and owner of Rij-Vrij Driving School. Certified instructor with expertise in autism & ADHD support. Based in Pijnacker."
>
  <div class="bg-white">

    <section class="py-20" style={`background-color: ${primaryColor}`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-white text-sm font-semibold uppercase tracking-widest mb-3">About us</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Let Us Introduce Ourselves</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">The person behind Rij-Vrij</p>
      </div>
    </section>

    <section class="py-20">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-2 text-sm font-semibold px-4 py-2 rounded-full mb-6" style={`background-color: ${primaryColor}15; color: ${primaryColor}`}>
              <Icon name="user-circle" />
              Driving Instructor &amp; Owner
            </div>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
              Hi, I'm <span style={`color: ${primaryColor}`}>Peter</span>
            </h2>
            <div class="space-y-5 text-gray-700 leading-relaxed">
              {bio.map((para, i) => (
                <p class={i === 1 ? 'text-lg font-medium text-gray-800' : ''}>{para}</p>
              ))}
              <p class="font-semibold text-gray-800 text-lg">See you behind the wheel soon!</p>
            </div>
            <div class="mt-8 flex flex-col sm:flex-row gap-4">
              <a href="/en/contact" class="inline-block text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md text-center" style={`background-color: ${primaryColor}`}>
                <Icon name="envelope" class="mr-2" />Get in touch
              </a>
              <a href="/en/#proefles-cta" class="inline-block text-white px-6 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md text-center" style={`background-color: ${secondaryColor}`}>
                <Icon name="calendar-check" class="mr-2" />Book a trial lesson
              </a>
            </div>
          </div>

          <div class="flex justify-center">
            <img src="/peter.png" alt="Peter — rijinstructeur Rij-Vrij" class="rounded-2xl shadow-xl max-h-[480px] object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">Our values</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {waarden.map((item) => (
            <div class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow border border-gray-100 overflow-hidden flex flex-col">
              <div class="flex items-center justify-center py-7" style={`background-color: ${primaryColor}`}>
                <i class={`fas ${item.icon} text-4xl text-white`}></i>
              </div>
              <div class="p-6 flex flex-col flex-grow text-center">
                <h3 class="font-bold text-gray-900 mb-2">{item.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 bg-white border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h3 class="text-xl font-bold text-gray-900 mb-2">Ready to get started?</h3>
        <p class="text-gray-600 text-sm mb-6">Book a free trial lesson and discover what Rij-Vrij can do for you.</p>
        <a href="/en/#proefles-cta" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
          <Icon name="calendar-check" class="mr-2" />Book free trial lesson
        </a>
      </div>
    </section>

  </div>
</Layout>
