---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

const primaryColor = '#0391b0';
const secondaryColor = '#790f34';
const opleidersnummer = '1460F3';

const stappen = [
  'Go to mijn.cbr.nl and log in with your DigiD',
  'Go to "Mijn rijvaardigheid" and choose "Rijschool machtigen"',
  `Enter the CBR instructor number: ${opleidersnummer}`,
  'For licence category B, select: "Praktijkexamen personenauto & Tussentijdse toets personenauto"',
  'Confirm the authorisation',
];

const nodig = [
  { icon: 'fa-id-badge', text: 'A DigiD account (apply at digid.nl if you do not have one yet)' },
];
import Icon from '../../components/Icon.astro';
---

<Layout
  title="Authorise Driving School"
  description="Authorise Rij-Vrij via mijn.cbr.nl so we can arrange your CBR exam. Step-by-step instructions. CBR instructor number: 1460F3."
>
  <div class="bg-white">

    <section class="py-20" style={`background: linear-gradient(135deg, ${primaryColor} 0%, ${secondaryColor} 100%)`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-white text-sm font-semibold uppercase tracking-widest mb-3">Via MijnCBR with DigiD</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Authorise Driving School</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">
          Authorise Rij-Vrij so we can arrange your CBR exam on your behalf.
        </p>
      </div>
    </section>

    <section class="py-10 bg-gray-50 border-b border-gray-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center gap-6 bg-white rounded-2xl p-6 shadow-sm border border-gray-100">
          <div class="w-14 h-14 rounded-xl flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}15`}>
            <Icon name="hashtag" class="text-2xl" style={`color: ${primaryColor}`} />
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gray-600 mb-1">CBR Instructor Number Rij-Vrij</p>
            <p class="text-3xl font-black text-gray-900 tracking-widest">{opleidersnummer}</p>
            <p class="text-gray-600 text-sm mt-1">Use this number at step 3 below</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
              <span class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}`}>
                <Icon name="list-check" class="text-white text-sm" />
              </span>
              What do you need?
            </h2>
            <div class="space-y-3">
              {nodig.map((item) => (
                <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}15`}>
                    <i class={`fas ${item.icon} text-sm`} style={`color: ${primaryColor}`}></i>
                  </div>
                  <span class="text-gray-700 text-sm leading-relaxed pt-1">{item.text}</span>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
              <span class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background-color: ${secondaryColor}`}>
                <Icon name="shoe-prints" class="text-white text-sm" />
              </span>
              How to authorise us?
            </h2>
            <div class="space-y-3">
              {stappen.map((stap, i) => (
                <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4 border border-gray-100">
                  <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-white font-bold text-sm" style={`background-color: ${primaryColor}`}>
                    {i + 1}
                  </div>
                  <p class="text-gray-700 text-sm leading-relaxed pt-1">{stap}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="mt-8 p-5 bg-amber-50 border border-amber-100 rounded-xl flex items-start gap-3">
          <Icon name="exclamation-triangle" class="text-amber-600 mt-0.5 flex-shrink-0" />
          <p class="text-amber-800 text-sm leading-relaxed">
            Please select the correct options to avoid confusion. Your instructor will help you if you are unsure.
          </p>
        </div>
      </div>
    </section>

    <section class="py-10 bg-gray-50 border-y border-gray-100">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex items-start gap-4">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style={`background-color: ${primaryColor}15`}>
          <Icon name="check-double" style={`color: ${primaryColor}`} />
        </div>
        <div>
          <p class="font-semibold text-gray-900 mb-1">Authorisation complete?</p>
          <p class="text-gray-600 text-sm leading-relaxed">
            Once the authorisation is confirmed, Rij-Vrij can schedule your exam. Contact us if you have any questions.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Questions?</h3>
        <p class="text-gray-600 mb-6">We are happy to help you step by step. Feel free to get in touch.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/en/contact" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
            <Icon name="envelope" class="mr-2" />Get in touch
          </a>
          <a href="/en/practical-exam" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${secondaryColor}`}>
            <Icon name="flag-checkered" class="mr-2" />About the practical exam
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>
