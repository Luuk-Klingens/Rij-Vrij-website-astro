---
import Layout from '../../layouts/Layout.astro';
import GoogleReviews from '../../components/GoogleReviews.astro';
import Icon from '../../components/Icon.astro';

export const prerender = true;

const green = '#223927';
const gold  = '#ac884d';
---

<Layout
  title="Reviews & Experiences"
  description="Read what students say about Rij-Vrij Refresher Lessons. Average 5 stars on Google. View experiences and leave your own review."
>

  <!-- ═══ HERO ═══ -->
  <section style={`background-color: ${green}`} class="py-20">
    <div class="section-container">
      <div style={`width: 2.5rem; height: 4px; background-color: ${gold}; margin-bottom: 1.5rem`}></div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4" style="line-height: 1.1">
        What do our students say?
      </h1>
      <p class="text-lg max-w-xl" style="color: rgba(255,255,255,0.70)">
        Our students rate us with 5 stars on Google. Read their experiences.
      </p>
    </div>
  </section>

  <!-- Diagonal transition -->
  <div style={`background-color: ${green}; overflow: hidden; height: 3rem`}>
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
      <path d="M0,0 L1440,48 L0,48 Z" fill="#faf8f4" />
    </svg>
  </div>

  <!-- ═══ STATS ═══ -->
  <section class="pt-4 pb-20" style="background-color: #faf8f4">
    <div class="section-container">

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-16">
        {[
          { icon: 'star', value: '5 stars', sub: 'Average rating on Google', color: gold },
          { icon: 'thumbs-up', value: '100%', sub: 'Would recommend Rij-Vrij to others', color: green },
          { icon: 'handshake', value: 'Honest', sub: 'Transparent rates, no hidden costs', color: green },
        ].map((s) => (
          <div class="card-dutch text-center flex flex-col items-center gap-3 py-8">
            <Icon name={s.icon} style={`color: ${s.color === gold ? gold : green}; font-size: 2rem`} />
            <div class="text-2xl font-extrabold" style={`color: ${green}`}>{s.value}</div>
            <p class="text-sm" style="color: #5c5c50">{s.sub}</p>
          </div>
        ))}
      </div>

      <!-- Reviews -->
      <div class="mb-8">
        <span class="gold-bar"></span>
        <h2 class="text-2xl font-extrabold mb-8" style={`color: ${green}`}>Reviews via Google</h2>
        <GoogleReviews />
      </div>

      <div class="text-center mt-8">
        <a
          href="https://www.google.com/maps/place/?q=place_id:ChIJ4_e8zzcXcw8RIQCtvKZxLko"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-green"
        >
          <Icon name="google" style="font-size:13px" />
          View all reviews on Google
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 bg-white border-t" style="border-color: #e4ddd0">
    <div class="section-container text-center">
      <span class="gold-bar-center"></span>
      <h3 class="text-2xl font-extrabold mb-3" style={`color: ${green}`}>Want to drive with confidence too?</h3>
      <p class="mb-7" style="color: #5c5c50">Book your refresher lesson today. Start immediately, no waiting times.</p>
      <a href="https://startmetjerijbewijs.nl/rij-vrij/inschrijven" target="_blank" rel="noopener noreferrer" class="btn-primary">
        <Icon name="file-alt" style="font-size:13px" />
        Sign up
      </a>
    </div>
  </section>

</Layout>
