---
import Layout from '../layouts/Layout.astro';

const primaryColor = '#0391b0';
const secondaryColor = '#790f34';
import Icon from '../components/Icon.astro';
---

<Layout
  title="Contact"
  description="Neem contact op met Rij-Vrij Rijschool. Bel 015-2224012 of mail naar info@Rij-Vrij.com. Gevestigd aan de Hankweg 39 in Pijnacker. Plan direct je proefles."
>
  <div class="bg-white">

    <!-- Header -->
    <section class="py-16" style={`background: linear-gradient(135deg, ${primaryColor} 0%, ${secondaryColor} 100%)`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Contact</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">Neem contact met ons op voor meer informatie of om een proefles in te plannen.</p>
      </div>
    </section>

    <!-- Content -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

          <!-- Contact info -->
          <div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-8">Contact Informatie</h2>

            <div class="space-y-5">
              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="phone" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Telefoon</h4>
                  <a href="tel:0152224012" class="hover:underline" style={`color: ${primaryColor}`}>
                    015-2224012
                  </a>
                </div>
              </div>

              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="envelope" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">E-mail</h4>
                  <a href="mailto:info@Rij-Vrij.com" class="hover:underline" style={`color: ${primaryColor}`}>
                    info@Rij-Vrij.com
                  </a>
                </div>
              </div>

              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="map-marker-alt" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Adres</h4>
                  <p class="text-gray-600">Hankweg 39, 2641 WV Pijnacker</p>
                </div>
              </div>

              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="clock" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Openingstijden</h4>
                  <p class="text-gray-600 text-sm">Maandag: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Dinsdag: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Woensdag: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Donderdag: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Vrijdag: 08:00 – 17:00</p>
                  <p class="text-gray-600 text-sm">Zaterdag: Op afspraak</p>
                  <p class="text-gray-600 text-sm">Zondag: Gesloten</p>
                </div>
              </div>

              <div class="flex items-start">
                <div class="w-12 h-12 rounded-xl flex items-center justify-center mr-4 flex-shrink-0" style={`background-color: ${primaryColor}`}>
                  <Icon name="map" class="text-white" />
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Lesgebied</h4>
                  <p class="text-gray-600 text-sm">Delft, Pijnacker, Zoetermeer, Rijswijk en 8 andere gemeenten</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Contact mogelijkheden -->
          <div>
            <h2 class="text-2xl font-semibold text-gray-900 mb-8">Neem contact op</h2>

            <p class="text-gray-600 mb-8 leading-relaxed">
              Neem direct contact met ons op via één van onderstaande manieren. Wij reageren zo snel mogelijk op je bericht.
            </p>

            <div class="space-y-4">
              <a
                href="mailto:info@Rij-Vrij.com?subject=Vraag%20via%20website"
                class="flex items-center gap-4 p-5 rounded-xl border-2 hover:shadow-md transition-all group"
                style={`border-color: ${primaryColor}`}
              >
                <div
                  class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
                  style={`background-color: ${primaryColor}`}
                >
                  <Icon name="envelope" class="text-white text-lg" />
                </div>
                <div>
                  <p class="font-bold text-gray-900">Stuur een e-mail</p>
                  <p class="text-sm" style={`color: ${primaryColor}`}>info@Rij-Vrij.com</p>
                </div>
                <Icon name="arrow-right" class="ml-auto text-gray-600 group-hover:text-gray-600 transition-colors" />
              </a>

              <a
                href="tel:0152224012"
                class="flex items-center gap-4 p-5 rounded-xl border-2 hover:shadow-md transition-all group"
                style={`border-color: ${primaryColor}`}
              >
                <div
                  class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0"
                  style={`background-color: ${primaryColor}`}
                >
                  <Icon name="phone" class="text-white text-lg" />
                </div>
                <div>
                  <p class="font-bold text-gray-900">Bel ons</p>
                  <p class="text-sm" style={`color: ${primaryColor}`}>015-2224012</p>
                </div>
                <Icon name="arrow-right" class="ml-auto text-gray-600 group-hover:text-gray-600 transition-colors" />
              </a>

              <a
                href="mailto:info@Rij-Vrij.com?subject=Proefles%20aanvraag"
                class="flex items-center justify-center gap-3 p-5 rounded-xl text-white font-bold text-lg hover:opacity-90 transition-all shadow-md"
                style={`background: linear-gradient(135deg, ${primaryColor} 0%, ${secondaryColor} 100%)`}
              >
                <Icon name="calendar-check" />
                Plan mijn proefles
              </a>
            </div>

            <p class="text-sm text-gray-600 mt-6">
              Voorkeur voor e-mail? Vermeld in je bericht je naam, telefoonnummer en eventueel je woonplaats, dan nemen wij zo snel mogelijk contact met je op.
            </p>
          </div>

        </div>
      </div>
    </section>

  </div>
</Layout>
