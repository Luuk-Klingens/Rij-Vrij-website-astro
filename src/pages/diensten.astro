---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const green = '#223927';
const gold  = '#ac884d';

const diensten = [
  {
    icon: 'redo',
    title: 'Algemene opfrisles',
    description: 'Al een tijd niet gereden? We beoordelen je rijvaardigheid en werken samen gericht aan de punten waar winst te halen valt.',
    features: ['Beoordeling rijvaardigheid', 'Gericht werken aan verbeterpunten', 'Eigen tempo, eigen stijl'],
  },
  {
    icon: 'road',
    title: 'Snelwegles',
    description: 'Invoegen, uitvoegen, veilig inhalen en rijden op snelheid. Specifiek gericht op snelwegrijden in automaat.',
    features: ['Invoegen & uitvoegen', 'Veilig inhalen op snelheid', 'Omgaan met file en afstand houden'],
  },
  {
    icon: 'parking',
    title: 'Parkeertraining',
    description: 'Inparkeren, haaks parkeren, achteruitrijden in smalle straten — praktische situaties in jouw eigen buurt.',
    features: ['Inparkeren & haaks parkeren', 'Smalle straten & parkeergarages', 'Achteruitrijden met zelfvertrouwen'],
  },
  {
    icon: 'heart',
    title: 'Rijangst overwinnen',
    description: 'Rustig en stap voor stap werken aan vertrouwen achter het stuur. Voor mensen die angst hebben opgebouwd na een incident of lange rijpauze.',
    features: ['Rustige, veilige begeleiding', 'Op jouw tempo — geen druk', 'Specialist autisme & ADHD'],
  },
  {
    icon: 'user-check',
    title: 'CBR rijtest (ouderen)',
    description: 'Speciale voorbereiding op de CBR rijtest die vereist is voor het verlengen van je rijbewijs na je 75e.',
    features: ['CBR-gericht oefenen', 'Alle toetsmomenten behandeld', 'Eerlijke beoordeling van rijvaardigheid'],
  },
  {
    icon: 'gift',
    title: 'Cadeaubon opfrisles',
    description: 'Geef een opfrisles cadeau aan iemand die je dierbaar is. Praktisch, persoonlijk en altijd welkom.',
    features: ['Cadeaubon beschikbaar', 'Flexibel in te wisselen', 'Persoonlijke boodschap mogelijk'],
  },
];
---

<Layout
  title="Opfrislessen — Wat bieden wij aan?"
  description="Rij-Vrij biedt professionele opfrislessen op maat: algemeen, snelweg, parkeren, rijangst en CBR rijtest voorbereiding. Automaat, regio Haaglanden, Delft & Zoetermeer."
>

  <!-- ═══ HERO ═══ -->
  <section style={`background-color: ${green}`} class="py-20">
    <div class="section-container">
      <div style={`width: 2.5rem; height: 4px; background-color: ${gold}; margin-bottom: 1.5rem`}></div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4" style="line-height: 1.1">
        Opfrislessen<br />op maat
      </h1>
      <p class="text-lg max-w-2xl" style="color: rgba(255,255,255,0.70)">
        Jij hebt de basis ooit geleerd. Wij helpen je die basis oppoetsen zodat je met plezier, veiligheid en zelfvertrouwen de weg op gaat. Alleen automaat, geen gedoe met schakelen.
      </p>
    </div>
  </section>

  <!-- Diagonale overgang -->
  <div style={`background-color: ${green}; overflow: hidden; height: 3rem`}>
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
      <path d="M0,0 L1440,48 L0,48 Z" fill="#faf8f4" />
    </svg>
  </div>

  <!-- ═══ DIENSTEN GRID ═══ -->
  <section class="pt-4 pb-20" style="background-color: #faf8f4">
    <div class="section-container">

      <div class="mb-12">
        <span class="gold-bar"></span>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style={`color: ${green}`}>Onze diensten</h2>
        <p class="text-base max-w-xl" style="color: #5c5c50">
          Kies de les die bij jouw situatie past — of laat ons een plan op maat maken.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {diensten.map((d) => (
          <div class="card-dutch flex flex-col gap-5">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
                <Icon name={d.icon} class="text-white" style="font-size:16px" />
              </div>
              <h3 class="font-extrabold" style={`color: ${green}`}>{d.title}</h3>
            </div>

            <p class="text-sm leading-relaxed" style="color: #5c5c50">{d.description}</p>

            <ul class="space-y-2 mt-auto">
              {d.features.map((f) => (
                <li class="flex items-center gap-2 text-sm" style="color: #374151">
                  <Icon name="check" style={`color: ${gold}; font-size:12px; flex-shrink:0`} />
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ USP BALK ═══ -->
  <section style={`background-color: ${green}`} class="py-12">
    <div class="section-container">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        {[
          { value: '100%', label: 'Automaat', sub: 'Altijd lessen in een automaat' },
          { value: '15+', label: 'Lesgebieden', sub: 'Haaglanden, Delft & Zoetermeer' },
          { value: '5★', label: 'Google', sub: 'Beoordeeld door onze leerlingen' },
        ].map((s) => (
          <div>
            <div class="text-4xl font-extrabold mb-1" style={`color: ${gold}`}>{s.value}</div>
            <div class="font-bold text-white text-sm">{s.label}</div>
            <div class="text-xs mt-1" style="color: rgba(255,255,255,0.55)">{s.sub}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 bg-white">
    <div class="section-container">
      <div class="flex flex-col lg:flex-row gap-8 items-center justify-between">
        <div>
          <span class="gold-bar"></span>
          <h3 class="text-2xl font-extrabold mb-2" style={`color: ${green}`}>Weet je nog niet welke les bij jou past?</h3>
          <p style="color: #5c5c50">Neem gewoon contact op — wij helpen je bepalen wat jouw situatie vraagt.</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 flex-shrink-0">
          <a href="/#opfrisles-cta" class="btn-primary">
            <Icon name="calendar-check" style="font-size:13px" />
            Plan opfrisles
          </a>
          <a href="/contact" class="btn-outline">
            <Icon name="envelope" style="font-size:13px" />
            Stel een vraag
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
