---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const green = '#223927';
const gold  = '#ac884d';

const aanpak = [
  { icon: 'user', title: 'Jij staat centraal', text: 'Jouw leerstijl, jouw veiligheid en jouw tempo bepalen het ritme van elke les.' },
  { icon: 'handshake', title: 'Vaste instructeur', text: 'Altijd dezelfde vertrouwde instructeur voor maximale continuïteit en herkenbaarheid.' },
  { icon: 'calendar-check', title: 'Duidelijke structuur', text: 'Voorspelbare lessen met een vaste opbouw, je weet precies wat je kunt verwachten.' },
  { icon: 'shield-alt', title: 'Minder prikkels', text: 'Extra aandacht voor sensorische prikkels en concentratiebehoud tijdens de rit.' },
  { icon: 'car', title: 'Altijd automaat', text: 'Geen schakelen, volledige focus op het verkeer. Dat maakt een groot verschil.' },
  { icon: 'heart', title: 'Geduld & begrip', text: 'Nooit druk, nooit haast. Jouw tempo is ons tempo, altijd.' },
];

const silvyReview = {
  name: 'Shiyanna Lucifer (Lucy)',
  photo: 'https://lh3.googleusercontent.com/a-/ALV-UjXHdmykFII6CFC4APW09O8hck0gu4kHT0hqYQNenZcnmTQmkxiS=s128-c0x00000000-cc-rp-mo',
  text: 'Geweldige rijschool! Peter is heel rustig, kalm, geduldig en bovenal eerlijk! Ook heb ik heerlijk met hem kunnen praten over van alles en nog wat. Er was een relaxte sfeer in de auto en alles was bespreekbaar. Hierdoor is mijn zelfvertrouwen achter het stuur ook flink gestegen. Dit was al met een extra moeilijkheidsgraad vanwege mijn ADHD, maar Peter wist hier heel goed mee om te gaan. Hij kon mij als het ware lezen en las al een pauze in, nog voordat ik zelf doorhad dat ik het toch eigenlijk wel nodig had. Super bedankt Peter!',
  date: '6 maanden geleden',
};
---

<Layout
  title="Opfrislessen bij Autisme & ADHD"
  description="Rij-Vrij is specialist in opfrislessen voor mensen met autisme of ADHD. Geduld, duidelijke structuur en aanpassing aan jouw tempo. Erkend bij rijles-en-autisme.nl. Pijnacker, regio Haaglanden."
>

  <!-- ═══ HERO ═══ -->
  <section style={`background-color: ${green}`} class="py-20">
    <div class="section-container">
      <div style={`width: 2.5rem; height: 4px; background-color: ${gold}; margin-bottom: 1.5rem`}></div>
      <p class="text-xs font-bold tracking-widest uppercase mb-3" style={`color: ${gold}`}>Erkend specialist</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4" style="line-height: 1.1">
        Autisme &amp; ADHD
      </h1>
      <p class="text-lg max-w-2xl mb-8" style="color: rgba(255,255,255,0.70)">
        Opfrislessen op jouw manier. Rij-Vrij begeleidt mensen met autisme of ADHD met kennis, geduld en een vaste structuur.
      </p>
      <div class="inline-flex items-center gap-3 px-5 py-3 text-sm font-bold text-white" style={`background-color: rgba(172,136,77,0.15); border-left: 3px solid ${gold}; border-radius: 0 4px 4px 0`}>
        <Icon name="certificate" style={`color: ${gold}; font-size:14px`} />
        Geregistreerd bij rijles-en-autisme.nl, onderdeel van Spectrum Brabant
      </div>
    </div>
  </section>

  <!-- Diagonale overgang -->
  <div style={`background-color: ${green}; overflow: hidden; height: 3rem`}>
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
      <path d="M0,0 L1440,48 L0,48 Z" fill="white" />
    </svg>
  </div>

  <!-- ═══ INFO + REVIEW ═══ -->
  <section class="pt-4 pb-20 bg-white">
    <div class="section-container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

        <!-- Info tekst -->
        <div>
          <span class="gold-bar"></span>
          <div class="space-y-4 text-base leading-relaxed" style="color: #374151">
            <p>
              Mensen met autisme (ASS), ADHD of vergelijkbare kenmerken kunnen prima autorijden en opfrislessen volgen. Omdat hun hersenen informatie soms anders verwerken, kan begeleiding net iets anders zijn; en daar zijn wij in gespecialiseerd.
            </p>
            <p>
              Rijschool Rij-Vrij is erkend specialist en staat geregistreerd bij <a href="https://www.rijles-en-autisme.nl" target="_blank" rel="noopener noreferrer" class="font-bold hover:opacity-70 transition-opacity" style={`color: ${green}`}>rijles-en-autisme.nl</a>, onderdeel van Spectrum Brabant, een centrum voor zorg en onderwijs gespecialiseerd in autisme en ADHD.
            </p>
            <p>
              Rijden in een automaat helpt extra: geen schakelen, volledig focussen op het verkeer. Dat geeft rust, overzicht en minder prikkels.
            </p>
            <p class="font-bold" style={`color: ${green}`}>
              Altijd op jouw tempo. Nooit druk, nooit haast.
            </p>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4 mt-8">
            <div class="p-5 text-center" style={`border: 2px solid #e4ddd0; border-top: 4px solid ${gold}; border-radius: 4px`}>
              <div class="text-3xl font-extrabold mb-1" style={`color: ${green}`}>100%</div>
              <div class="text-sm" style="color: #5c5c50">Automaat, minder afleiding</div>
            </div>
            <div class="p-5 text-center" style={`border: 2px solid #e4ddd0; border-top: 4px solid ${gold}; border-radius: 4px`}>
              <div class="text-3xl font-extrabold mb-1" style={`color: ${green}`}>Erkend</div>
              <div class="text-sm" style="color: #5c5c50">Rijles-en-autisme.nl</div>
            </div>
          </div>
        </div>

        <!-- Silvy review -->
        <div style={`border: 2px solid #e4ddd0; border-left: 4px solid ${gold}; border-radius: 0 4px 4px 0; background: #faf8f4; padding: 2rem`}>
          <p class="text-xs font-bold uppercase tracking-widest mb-5" style={`color: ${gold}`}>Wat een leerling over ons zei</p>

          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <Icon name="star" class="text-yellow-400 text-lg" />
            ))}
          </div>

          <p class="text-sm leading-relaxed italic mb-6" style="color: #374151">
            "{silvyReview.text}"
          </p>

          <div class="flex items-center gap-3 border-t pt-5" style="border-color: #e4ddd0">
            <img
              src={silvyReview.photo}
              alt={silvyReview.name}
              width="44" height="44" loading="lazy"
              style="width:44px;height:44px;border-radius:2px;object-fit:cover;flex-shrink:0"
            />
            <div>
              <p class="font-bold text-sm" style={`color: ${green}`}>{silvyReview.name}</p>
              <p class="text-xs" style="color: #5c5c50">{silvyReview.date} · Google Review</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ ONZE AANPAK ═══ -->
  <section class="py-20" style="background-color: #faf8f4">
    <div class="section-container">

      <div class="mb-12 text-center">
        <span class="gold-bar-center"></span>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style={`color: ${green}`}>Onze aanpak</h2>
        <p class="max-w-xl mx-auto" style="color: #5c5c50">
          Elke les is afgestemd op jouw behoeften. Zo ziet een opfrisles bij Rij-Vrij er voor jou uit.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {aanpak.map((item) => (
          <div class="card-dutch flex flex-col gap-4">
            <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
              <Icon name={item.icon} class="text-white" style="font-size:16px" />
            </div>
            <div>
              <h3 class="font-extrabold mb-2" style={`color: ${green}`}>{item.title}</h3>
              <p class="text-sm leading-relaxed" style="color: #5c5c50">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 bg-white border-t" style="border-color: #e4ddd0">
    <div class="section-container text-center">
      <span class="gold-bar-center"></span>
      <h3 class="text-2xl font-extrabold mb-3" style={`color: ${green}`}>Klaar om te starten?</h3>
      <p class="mb-7" style="color: #5c5c50">
        Plan een opfrisles of stel je vraag. Wij helpen je graag op weg, op jouw tempo.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/#opfrisles-cta" class="btn-primary">
          <Icon name="calendar-check" style="font-size:13px" />
          Plan opfrisles
        </a>
        <a href="/contact" class="btn-outline">
          <Icon name="envelope" style="font-size:13px" />
          Neem contact op
        </a>
      </div>
    </div>
  </section>

</Layout>
