---
import Layout from '../layouts/Layout.astro';

const primaryColor = '#0391b0';
const secondaryColor = '#790f34';
const kosten = '€45,25';

const stappen = [
  'Log in op mijn.cbr.nl met je DigiD',
  'Ga naar "Gezondheidsverklaring aanvragen"',
  'Vul de vragen eerlijk in',
  'Dien de verklaring op tijd in zodat het CBR deze kan verwerken voor je examen',
];
import Icon from '../components/Icon.astro';
---

<Layout title="Gezondheidsverklaring">
  <div class="bg-white">

    <!-- Header -->
    <section class="py-20" style={`background: linear-gradient(135deg, ${primaryColor} 0%, ${secondaryColor} 100%)`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-white text-sm font-semibold uppercase tracking-widest mb-3">Verplicht voor je examen</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">Gezondheidsverklaring</h1>
        <p class="text-xl text-white max-w-2xl mx-auto">
          Voor het aanvragen van een praktijkexamen bij het CBR is een geldige gezondheidsverklaring verplicht.
        </p>
        <div class="mt-8 inline-block bg-white/20 backdrop-blur-sm border border-white/30 text-white font-bold text-xl px-8 py-4 rounded-2xl">
          {kosten} <span class="text-base font-normal">via mijn.cbr.nl</span>
        </div>
      </div>
    </section>

    <!-- Hoe aanvragen -->
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-3">
              <span class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={`background-color: ${primaryColor}`}>
                <Icon name="laptop" class="text-white text-sm" />
              </span>
              Hoe vraag je het aan?
            </h2>
            <p class="text-gray-600 text-sm mb-4 leading-relaxed">
              Je vraagt de gezondheidsverklaring zelf aan via mijn.cbr.nl. Dit doe je apart van de rijschool: het is jouw eigen verantwoordelijkheid.
            </p>
            <div class="space-y-3">
              {stappen.map((stap, i) => (
                <div class="flex items-start gap-4 bg-gray-50 rounded-xl p-4 border border-gray-100">
                  <div
                    class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-white font-bold text-sm"
                    style={`background-color: ${primaryColor}`}
                  >
                    {i + 1}
                  </div>
                  <p class="text-gray-700 text-sm leading-relaxed pt-1">{stap}</p>
                </div>
              ))}
            </div>
          </div>

          <div class="space-y-6">
            <!-- Kosten -->
            <div class="bg-gray-50 rounded-xl p-6 border border-gray-100">
              <h3 class="font-bold text-gray-900 mb-2 flex items-center gap-2">
                <Icon name="euro-sign" style={`color: ${primaryColor}`} />
                Kosten
              </h3>
              <p class="text-gray-600 text-sm leading-relaxed">
                De gezondheidsverklaring kost <strong>{kosten}</strong> en wordt direct via het CBR afgehandeld. Dit bedrag is niet inbegrepen in onze rijpakketten.
              </p>
            </div>

            <!-- Goed nieuws -->
            <div class="rounded-xl p-6" style={`background: ${primaryColor}10`}>
              <h3 class="font-bold text-gray-900 mb-2 flex items-center gap-2">
                <Icon name="star" style={`color: ${primaryColor}`} />
                Goed nieuws voor autisme en ADHD
              </h3>
              <p class="text-gray-600 text-sm leading-relaxed">
                Per 1 december 2025 worden mensen met ADHD of autisme niet langer doorverwezen voor aanvullende medische keuringen. De verwachting is dat ADHD en autisme per 1 april 2026 volledig verdwijnen uit de Gezondheidsverklaring.
              </p>
              <a
                href="/autisme-adhd"
                class="inline-flex items-center gap-1 mt-3 text-sm font-semibold hover:underline"
                style={`color: ${primaryColor}`}
              >
                Meer lezen over autisme en ADHD <Icon name="arrow-right" class="text-xs" />
              </a>
            </div>

            <!-- Let op -->
            <div class="p-5 bg-amber-50 border border-amber-100 rounded-xl flex items-start gap-3">
              <Icon name="exclamation-triangle" class="text-amber-600 mt-0.5 flex-shrink-0" />
              <p class="text-amber-800 text-sm leading-relaxed">
                Vraag de gezondheidsverklaring op tijd aan. Het CBR heeft verwerkingstijd nodig voordat je examen door kan gaan.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-gray-50 border-t border-gray-100">
      <div class="max-w-2xl mx-auto px-4 text-center">
        <h3 class="text-2xl font-bold text-gray-900 mb-3">Vragen over de aanvraag?</h3>
        <p class="text-gray-600 mb-6">Wij helpen je graag verder. Neem gerust contact op.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${primaryColor}`}>
            <Icon name="envelope" class="mr-2" />Neem contact op
          </a>
          <a href="/examen-praktijk" class="inline-block text-white px-7 py-3 rounded-lg font-semibold hover:opacity-90 transition-all shadow-md" style={`background-color: ${secondaryColor}`}>
            <Icon name="flag-checkered" class="mr-2" />Over het praktijkexamen
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>
