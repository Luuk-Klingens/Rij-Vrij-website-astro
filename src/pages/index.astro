---
import Layout from '../layouts/Layout.astro';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';
import lesgebieden from '../data/lesgebieden';
import Icon from '../components/Icon.astro';

const green = '#223927';
const gold  = '#ac884d';

const diensten = [
  {
    icon: 'redo',
    title: 'Algemene opfrisles',
    text: 'Al een tijd niet gereden? We beoordelen je rijvaardigheid en werken gericht aan de punten waar je winst kunt halen.',
  },
  {
    icon: 'road',
    title: 'Snelwegles',
    text: 'Invoegen, uitvoegen, veilig inhalen en rijden op snelheid. Specifiek gericht op snelweg en autosnelwegrijden.',
  },
  {
    icon: 'parking',
    title: 'Parkeertraining',
    text: 'Inparkeren, haaks parkeren, achteruitrijden in smalle straten. Wij herhalen tot het zit.',
  },
  {
    icon: 'heart',
    title: 'Rijangst overwinnen',
    text: 'Rustig en veilig werken aan vertrouwen. Voor mensen die angst hebben opgebouwd na een incident of lange pauze.',
  },
  {
    icon: 'user-check',
    title: 'CBR rijtest (ouderen)',
    text: 'Speciale voorbereiding op de CBR rijtest die vereist is voor het verlengen van je rijbewijs na je 75e.',
  },
  {
    icon: 'gift',
    title: 'Cadeaubon',
    text: 'Geef een opfrisles cadeau aan iemand die je dierbaar is. Praktisch, persoonlijk en altijd welkom.',
  },
];

const waaromItems = [
  { icon: 'car', title: '100% automaat', text: 'Geen schakelen, volle aandacht voor het verkeer. Rustiger rijden, sneller resultaat.' },
  { icon: 'heart', title: 'Specialist autisme & ADHD', text: 'Erkend bij rijles-en-autisme.nl. Lessen op jouw tempo, met geduld en duidelijke structuur.' },
  { icon: 'map-pin', title: '15+ lesgebieden', text: 'Actief in heel regio Haaglanden, Delft en Zoetermeer. Wij komen naar jou toe.' },
  { icon: 'clock', title: 'Geen wachttijden', text: 'Direct starten. Vandaag aanmelden, zo snel mogelijk achter het stuur.' },
];

const pakketten = [
  {
    name: 'Opfris Start',
    sub: '3 lessen × 90 minuten',
    price: '299',
    popular: false,
    features: [
      'Beoordeling huidige rijvaardigheid',
      'Gericht werken aan verbeterpunten',
      'Vaste instructeur elke les',
      'Direct starten',
    ],
  },
  {
    name: 'Opfris Plus',
    sub: '5 lessen × 90 minuten',
    price: '479',
    popular: true,
    features: [
      'Alles van Opfris Start',
      'Extra aandacht voor specifieke situaties',
      'Stadsverkeer én snelweg',
      'Betaling in 2 termijnen mogelijk',
      'Direct starten',
    ],
  },
  {
    name: 'Opfris Volledig',
    sub: '8 lessen × 90 minuten',
    price: '749',
    popular: false,
    features: [
      'Volledig opfrisprogramma',
      'Alle verkeerssituaties behandeld',
      'Optioneel: CBR rijtest voorbereiding',
      'Betaling in 3 termijnen mogelijk',
      'Direct starten',
    ],
  },
];

const ctaBullets = [
  'Maatwerk — we starten met een beoordeling van je huidig niveau',
  'Vaste instructeur voor continuïteit en vertrouwen',
  'Alleen automaat — minder afleiding, meer focus op het verkeer',
  'Specialist autisme & ADHD — altijd geduld en duidelijkheid',
];
---

<Layout
  title="Opfrislessen — Rij-Vrij Rijschool Haaglanden & Delft"
  description="Rij-Vrij biedt professionele opfrislessen in automaat. Rijangst, snelweg, parkeren of gewoon weer vertrouwen krijgen. Specialist autisme & ADHD. Direct starten, geen wachttijden."
>
  <link slot="head" rel="preload" as="image" href="/hero-768.webp" type="image/webp"
    imagesrcset="/hero-768.webp 768w, /hero-1080.webp 1080w, /hero-1440.webp 1440w"
    imagesizes="100vw" fetchpriority="high" />

  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "DrivingSchool",
    "name": "Rij-Vrij Rijschool",
    "alternateName": ["RijVrij Rijschool", "Rij-Vrij Opfrislessen"],
    "url": "https://rij-vrij.nl",
    "telephone": "+31152224012",
    "email": "info@rij-vrij.nl",
    "image": "https://rij-vrij.nl/og-image.png",
    "priceRange": "€€",
    "sameAs": [
      "https://www.facebook.com/profile.php?id=61569989527327",
      "https://www.instagram.com/rij_vrij/",
      "https://www.tiktok.com/@rij.vrij/"
    ],
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Hankweg 39",
      "addressLocality": "Pijnacker",
      "postalCode": "2641 WV",
      "addressCountry": "NL"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 52.0169, "longitude": 4.4306 },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "08:00", "closes": "17:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "17:00" }
    ],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "9.7", "ratingCount": "47", "bestRating": "10" },
    "areaServed": lesgebieden.map(g => ({ "@type": "City", "name": g.naam }))
  })} />

  <!-- ═══════════════════════════════════════════════════════
       HERO — Diagonale split (Dutch Design)
  ═══════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="min-height: 640px">

    <!-- Witte rechterkant (vol breedte op mobile, geclipped op desktop) -->
    <div class="absolute inset-0 bg-white"></div>

    <!-- Groene linkerkant met diagonale rand — desktop only -->
    <div class="absolute inset-0 hidden lg:block" style={`background-color: ${green}; clip-path: polygon(0 0, 60% 0, 52% 100%, 0 100%)`}></div>

    <!-- Gouden diagonale accent-lijn — desktop only -->
    <div class="absolute inset-0 hidden lg:block" style={`background-color: ${gold}; clip-path: polygon(60% 0, 62.5% 0, 54.5% 100%, 52% 100%)`}></div>

    <!-- Mobile: volledige groene achtergrond -->
    <div class="absolute inset-0 lg:hidden" style={`background-color: ${green}`}></div>

    <!-- Content grid -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-[640px] flex items-center">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 w-full py-16 lg:py-24">

        <!-- LINKS — groene kant -->
        <div class="flex flex-col justify-center lg:pr-20">
          <div class="mb-6">
            <span class="inline-block text-xs font-bold tracking-widest uppercase px-3 py-1" style={`background-color: ${gold}; color: ${green}; border-radius: 2px`}>
              Opfrislessen
            </span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6" style="line-height: 1.1">
            Vertrouwen<br />terug<br />achter<br />het stuur.
          </h1>

          <p class="text-lg mb-8 leading-relaxed max-w-md" style="color: rgba(255,255,255,0.75)">
            Je rijbewijs heb je al. Rij-Vrij helpt je er alles uit te halen — rustig, doelgericht en op jouw tempo. Alleen automaat, regio Haaglanden, Delft &amp; Zoetermeer.
          </p>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="#opfrisles-cta" class="btn-primary">
              <Icon name="calendar-check" style="font-size:14px" />
              Plan mijn opfrisles
            </a>
            <a href="tel:0152224012" class="btn-outline-white">
              <Icon name="phone" style="font-size:14px" />
              015-2224012
            </a>
          </div>
        </div>

        <!-- RECHTS — witte kant (desktop only) -->
        <div class="hidden lg:flex flex-col justify-center pl-20">
          <div class="space-y-4">

            <!-- Stat cards: Dutch Design stijl -->
            {[
              { value: '100%', label: 'Automaat', sub: 'Geen schakelen — meer focus op het verkeer' },
              { value: '15+', label: 'Lesgebieden', sub: 'Haaglanden, Delft & Zoetermeer' },
              { value: '5★', label: 'Waardering', sub: 'Beoordeeld door onze leerlingen' },
            ].map((stat) => (
              <div class="flex items-center gap-4 p-4 bg-white" style="border-left: 4px solid #ac884d; border-radius: 0 4px 4px 0; box-shadow: 0 2px 12px rgba(34,57,39,0.08)">
                <div class="text-3xl font-extrabold flex-shrink-0" style={`color: ${green}; min-width: 64px`}>{stat.value}</div>
                <div>
                  <div class="font-bold text-sm" style={`color: ${green}`}>{stat.label}</div>
                  <div class="text-xs" style="color: #5c5c50">{stat.sub}</div>
                </div>
              </div>
            ))}

            <!-- CBR badge -->
            <div class="flex items-center gap-3 px-4 py-3" style={`background-color: ${green}; border-radius: 4px`}>
              <Icon name="certificate" style={`color: ${gold}; font-size:16px; flex-shrink:0`} />
              <span class="text-xs font-bold text-white">Erkend specialist autisme &amp; ADHD · rijles-en-autisme.nl</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       DIENSTEN — Wat bieden wij aan?
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 bg-white">
    <div class="section-container">

      <div class="mb-14">
        <span class="gold-bar"></span>
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-3" style={`color: ${green}`}>
          Opfrislessen op maat
        </h2>
        <p class="text-base max-w-xl" style="color: #5c5c50">
          Of je nu lang niet gereden hebt, snelwegangst hebt of wil oefenen voor de CBR rijtest — wij maken een plan op jouw situatie.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {diensten.map((d) => (
          <div class="card-dutch flex flex-col gap-4">
            <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${green}; border-radius: 4px`}>
              <Icon name={d.icon} class="text-white" style="font-size:16px" />
            </div>
            <div>
              <h3 class="font-bold mb-2" style={`color: ${green}`}>{d.title}</h3>
              <p class="text-sm leading-relaxed" style="color: #5c5c50">{d.text}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <a href="/diensten" class="btn-outline">
          Bekijk alle diensten <Icon name="arrow-right" style="font-size:12px" />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       WAAROM RIJ-VRIJ — op donkergroene band
  ═══════════════════════════════════════════════════════════ -->
  <section style={`background-color: ${green}`} class="py-20">
    <div class="section-container">

      <div class="mb-12">
        <span class="block mb-4" style={`width: 3rem; height: 4px; background-color: ${gold}`}></span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-3">
          Waarom Rij-Vrij?
        </h2>
        <p class="text-base" style="color: rgba(255,255,255,0.65)">
          Professioneel, persoonlijk en altijd automaat.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {waaromItems.map((item) => (
          <div class="p-6 flex flex-col gap-4" style={`background-color: rgba(255,255,255,0.06); border-left: 3px solid ${gold}`}>
            <div class="w-10 h-10 flex items-center justify-center flex-shrink-0" style={`background-color: ${gold}; border-radius: 4px`}>
              <Icon name={item.icon} style={`color: ${green}; font-size:16px`} />
            </div>
            <div>
              <h3 class="font-bold text-white mb-2 text-sm">{item.title}</h3>
              <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.65)">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       REVIEWS — op donkergroene achtergrond
  ═══════════════════════════════════════════════════════════ -->
  <section style={`background-color: ${green}`} class="pb-20 overflow-hidden">

    <div class="section-container mb-10">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4">
        <div>
          <div class="flex gap-1 mb-2">
            {[...Array(5)].map(() => <Icon name="star" class="text-yellow-400 text-lg" />)}
          </div>
          <p class="text-sm font-bold text-white">5 sterren op Google</p>
        </div>
        <a href="/reviews" class="text-sm font-bold transition-opacity hover:opacity-75" style={`color: ${gold}`}>
          Bekijk alle reviews →
        </a>
      </div>
    </div>

    <div class="px-4 sm:px-6 lg:px-8">
      <ReviewsCarousel />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       PAKKETTEN
  ═══════════════════════════════════════════════════════════ -->
  <section class="py-20 bg-white">
    <div class="section-container">

      <div class="mb-14 text-center">
        <span class="gold-bar-center"></span>
        <h2 class="text-3xl sm:text-4xl font-extrabold mb-3" style={`color: ${green}`}>
          Opfris pakketten
        </h2>
        <p class="text-base max-w-xl mx-auto" style="color: #5c5c50">
          Losse les of een pakket — wij starten altijd met een korte beoordeling van jouw rijvaardigheid.
          Alle pakketten in automaat, geen verborgen kosten.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
        {pakketten.map((pkg) => (
          <div class={`flex flex-col relative bg-white ${pkg.popular ? 'scale-[1.03]' : ''}`}
            style={`border: 2px solid ${pkg.popular ? gold : '#e4ddd0'}; border-top: 4px solid ${pkg.popular ? gold : green}; border-radius: 4px; box-shadow: ${pkg.popular ? '0 8px 32px rgba(34,57,39,0.12)' : '0 2px 12px rgba(34,57,39,0.06)'}`}>

            {pkg.popular && (
              <div class="text-center py-2 text-xs font-bold tracking-widest uppercase text-white" style={`background-color: ${gold}`}>
                Meest gekozen
              </div>
            )}

            <div class="p-8 flex flex-col flex-grow">
              <h3 class="text-xl font-extrabold mb-1" style={`color: ${green}`}>{pkg.name}</h3>
              <p class="text-sm mb-6" style="color: #5c5c50">{pkg.sub}</p>

              <div class="mb-6">
                <span class="text-4xl font-extrabold" style={`color: ${green}`}>€{pkg.price}</span>
                <span class="text-sm ml-1" style="color: #5c5c50">,-</span>
              </div>

              <ul class="flex-grow space-y-3 mb-8">
                {pkg.features.map((f) => (
                  <li class="flex items-start gap-2.5 text-sm" style="color: #374151">
                    <Icon name="check" style={`color: ${gold}; font-size:13px; flex-shrink:0; margin-top:2px`} />
                    {f}
                  </li>
                ))}
              </ul>

              <a
                href="#opfrisles-cta"
                class={pkg.popular ? 'btn-primary justify-center' : 'btn-outline justify-center'}
                style={pkg.popular ? '' : `border-color: ${green}; color: ${green}`}
              >
                Aanmelden
              </a>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-sm mt-8" style="color: #5c5c50">
        Losse les (90 min): <strong style={`color: ${green}`}>€109,-</strong>
        &nbsp;·&nbsp;
        Intakeles / beoordeling (60 min): <strong style={`color: ${green}`}>€69,-</strong>
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CTA — Aanmelding formulier (diagonale split)
  ═══════════════════════════════════════════════════════════ -->
  <section id="opfrisles-cta" class="py-20" style="background-color: #faf8f4">
    <div class="section-container">
      <div class="overflow-hidden" style={`border-left: 4px solid ${gold}; border-radius: 0 4px 4px 0; box-shadow: 0 4px 32px rgba(34,57,39,0.10)`}>

        <div class="grid grid-cols-1 lg:grid-cols-2">

          <!-- Links: info -->
          <div class="p-10 lg:p-12" style={`background-color: ${green}`}>

            <!-- Gouden accent streep -->
            <div style={`width: 2.5rem; height: 4px; background-color: ${gold}; margin-bottom: 1.5rem`}></div>

            <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-3">
              Plan je opfrisles bij Rij-Vrij
            </h2>
            <p class="text-sm mb-8" style="color: rgba(255,255,255,0.65)">
              Vul het formulier in en wij nemen zo snel mogelijk contact op. Vrijblijvend.
            </p>

            <ul class="space-y-3">
              {ctaBullets.map((b) => (
                <li class="flex items-start gap-3 text-sm" style="color: rgba(255,255,255,0.85)">
                  <Icon name="check" style={`color: ${gold}; font-size:13px; flex-shrink:0; margin-top:2px`} />
                  {b}
                </li>
              ))}
            </ul>
          </div>

          <!-- Rechts: formulier -->
          <div class="bg-white p-10 lg:p-12 flex flex-col justify-center">
            <form id="opfrisles-form" class="space-y-3">

              <div id="opfrisles-success" class="hidden p-4 text-sm flex items-center gap-2" style={`background-color: rgba(34,57,39,0.08); border-left: 3px solid ${green}; color: ${green}`}>
                <Icon name="check-circle" style="font-size:14px; flex-shrink:0" />
                <p><strong>Verzonden!</strong> Wij nemen snel contact op.</p>
              </div>
              <div id="opfrisles-error" class="hidden p-4 text-sm flex items-center gap-2" style="background-color: rgba(239,68,68,0.08); border-left: 3px solid #ef4444; color: #b91c1c">
                <Icon name="exclamation-circle" style="font-size:14px; flex-shrink:0" />
                <p id="opfrisles-error-text">Er ging iets mis. Probeer later opnieuw.</p>
              </div>

              {['naam', 'telefoon', 'adres', 'woonplaats'].map((field) => (
                <input
                  type={field === 'telefoon' ? 'tel' : 'text'}
                  name={field}
                  required
                  placeholder={field.charAt(0).toUpperCase() + field.slice(1)}
                  class="w-full px-4 py-3 text-sm outline-none transition"
                  style={`border: 2px solid #e4ddd0; border-radius: 4px; background: #faf8f4; color: #1a1a18`}
                />
              ))}

              <button
                type="submit"
                id="opfrisles-btn"
                class="w-full py-3.5 font-bold text-sm tracking-wide transition-all duration-150 cursor-pointer"
                style={`background-color: ${gold}; color: ${green}; border-radius: 4px; border: none`}
              >
                <span id="opfrisles-label">Opfrisles aanvragen</span>
              </button>
            </form>
          </div>

        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form     = document.getElementById('opfrisles-form') as HTMLFormElement;
  const btn      = document.getElementById('opfrisles-btn') as HTMLButtonElement;
  const label    = document.getElementById('opfrisles-label') as HTMLSpanElement;
  const success  = document.getElementById('opfrisles-success') as HTMLDivElement;
  const errorBox = document.getElementById('opfrisles-error') as HTMLDivElement;
  const errorTxt = document.getElementById('opfrisles-error-text') as HTMLParagraphElement;

  const inputs = form?.querySelectorAll('input');
  inputs?.forEach((input) => {
    input.addEventListener('focus', () => {
      (input as HTMLInputElement).style.borderColor = '#223927';
      (input as HTMLInputElement).style.background  = '#fff';
    });
    input.addEventListener('blur', () => {
      (input as HTMLInputElement).style.borderColor = '#e4ddd0';
      (input as HTMLInputElement).style.background  = '#faf8f4';
    });
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    label.textContent = 'Verzenden...';
    success.classList.add('hidden');
    errorBox.classList.add('hidden');
    try {
      const res  = await fetch('/api/proefles', { method: 'POST', body: new FormData(form) });
      let json: { ok: boolean; error?: string } | null = null;
      try { json = await res.json(); } catch {
        errorTxt.textContent = `Serverfout (${res.status}).`;
        errorBox.classList.remove('hidden');
        return;
      }
      if (json?.ok) { form.reset(); success.classList.remove('hidden'); }
      else { errorTxt.textContent = json?.error ?? 'Er ging iets mis.'; errorBox.classList.remove('hidden'); }
    } catch {
      errorTxt.textContent = 'Geen verbinding. Controleer je internet.';
      errorBox.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      label.textContent = 'Opfrisles aanvragen';
    }
  });
</script>
