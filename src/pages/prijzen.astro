---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const green = '#223927';
const gold  = '#ac884d';

const pakketten = [
  {
    name: 'Opfris Start',
    sub: '3 lessen × 90 minuten',
    price: '299',
    popular: false,
    features: [
      'Beoordeling huidige rijvaardigheid',
      'Gericht werken aan verbeterpunten',
      'Vaste instructeur elke les',
      'Direct starten',
    ],
    termijn: null,
  },
  {
    name: 'Opfris Plus',
    sub: '5 lessen × 90 minuten',
    price: '479',
    popular: true,
    features: [
      'Alles van Opfris Start',
      'Extra aandacht voor specifieke situaties',
      'Stadsverkeer én snelwegrijden',
      'Betaling in 2 termijnen mogelijk',
      'Direct starten',
    ],
    termijn: '2 termijnen',
  },
  {
    name: 'Opfris Volledig',
    sub: '8 lessen × 90 minuten',
    price: '749',
    popular: false,
    features: [
      'Volledig opfrisprogramma',
      'Alle verkeerssituaties behandeld',
      'Optioneel: CBR rijtest voorbereiding',
      'Betaling in 3 termijnen mogelijk',
      'Direct starten',
    ],
    termijn: '3 termijnen',
  },
];

const tariefRows = [
  { naam: 'Intakeles / beoordeling rijvaardigheid (60 min)', prijs: '€ 69,00' },
  { naam: 'Losse opfrisles (90 min)', prijs: '€ 109,00' },
  { naam: 'Snelwegles specifiek (90 min)', prijs: '€ 109,00' },
  { naam: 'Parkeertraining (60 min)', prijs: '€ 69,00' },
  { naam: 'CBR rijtest voorbereiding (90 min)', prijs: '€ 109,00' },
];
---

<Layout
  title="Tarieven Opfrislessen"
  description="Bekijk de tarieven van Rij-Vrij voor opfrislessen. Pakketten vanaf €299 voor 3 lessen. Transparante prijzen, geen verborgen kosten. Direct starten in regio Haaglanden, Delft & Zoetermeer."
>

  <!-- ═══ HERO HEADER ═══ -->
  <section style={`background-color: ${green}`} class="py-20">
    <div class="section-container">
      <div style={`width: 2.5rem; height: 4px; background-color: ${gold}; margin-bottom: 1.5rem`}></div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4" style="line-height: 1.1">
        Tarieven
      </h1>
      <p class="text-lg max-w-2xl" style="color: rgba(255,255,255,0.70)">
        Eerlijke, transparante tarieven voor opfrislessen. Geen verborgen kosten, geen kleine lettertjes.
      </p>
    </div>
  </section>

  <!-- Diagonale overgang groen → wit -->
  <div style={`background-color: ${green}; overflow: hidden; height: 3rem`}>
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
      <path d="M0,0 L1440,48 L0,48 Z" fill="white" />
    </svg>
  </div>

  <!-- ═══ PAKKETTEN ═══ -->
  <section class="pt-4 pb-20 bg-white">
    <div class="section-container">

      <div class="mb-12">
        <span class="gold-bar"></span>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style={`color: ${green}`}>Opfris pakketten</h2>
        <p class="text-base" style="color: #5c5c50">Alle pakketten zijn in automaat. We starten altijd met een beoordeling van jouw huidig rijvaardigheid.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
        {pakketten.map((pkg) => (
          <div class={`flex flex-col bg-white ${pkg.popular ? 'scale-[1.03]' : ''}`}
            style={`border: 2px solid ${pkg.popular ? gold : '#e4ddd0'}; border-top: 4px solid ${pkg.popular ? gold : green}; border-radius: 4px; box-shadow: ${pkg.popular ? '0 8px 32px rgba(34,57,39,0.12)' : '0 2px 12px rgba(34,57,39,0.06)'}`}>

            {pkg.popular && (
              <div class="text-center py-2 text-xs font-bold tracking-widest uppercase text-white" style={`background-color: ${gold}`}>
                Meest gekozen
              </div>
            )}

            <div class="p-7 flex flex-col flex-grow">
              <h3 class="text-xl font-extrabold mb-1" style={`color: ${green}`}>{pkg.name}</h3>
              <p class="text-sm mb-5" style="color: #5c5c50">{pkg.sub}</p>

              <div class="mb-6">
                <span class="text-4xl font-extrabold" style={`color: ${green}`}>€{pkg.price}</span>
                <span class="text-sm ml-1" style="color: #5c5c50">,-</span>
                {pkg.termijn && (
                  <p class="text-xs mt-1" style="color: #5c5c50">Betaling in {pkg.termijn} mogelijk</p>
                )}
              </div>

              <ul class="flex-grow space-y-2.5 mb-7">
                {pkg.features.map((f) => (
                  <li class="flex items-start gap-2.5 text-sm" style="color: #374151">
                    <Icon name="check" style={`color: ${gold}; font-size:13px; flex-shrink:0; margin-top:2px`} />
                    {f}
                  </li>
                ))}
              </ul>

              <a
                href="/#opfrisles-cta"
                class={pkg.popular ? 'btn-primary justify-center' : 'btn-outline justify-center'}
                style={pkg.popular ? '' : `border-color: ${green}; color: ${green}`}
              >
                Aanmelden
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ LOSSE TARIEVEN ═══ -->
  <section class="py-16" style="background-color: #faf8f4">
    <div class="section-container">

      <div class="mb-10">
        <span class="gold-bar"></span>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-2" style={`color: ${green}`}>Losse tarieven</h2>
        <p class="text-base" style="color: #5c5c50">Liever los boeken? Geen pakket nodig.</p>
      </div>

      <div class="max-w-2xl" style="border: 2px solid #e4ddd0; border-left: 4px solid #ac884d; border-radius: 0 4px 4px 0; background: white; box-shadow: 0 2px 12px rgba(34,57,39,0.06)">
        {tariefRows.map((row, i) => (
          <div class={`flex justify-between items-start gap-4 px-6 py-4 text-sm ${i < tariefRows.length - 1 ? 'border-b' : ''}`} style="border-color: #f0ebe2">
            <span style="color: #374151">{row.naam}</span>
            <span class="font-extrabold whitespace-nowrap" style={`color: ${green}`}>{row.prijs}</span>
          </div>
        ))}
      </div>

      <p class="text-sm mt-5" style="color: #5c5c50">
        Tarieven per 1 januari 2026. Alle rijlessen zijn inclusief gebruik van de lesauto (automaat).
      </p>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="py-16 bg-white border-t" style="border-color: #e4ddd0">
    <div class="section-container text-center">
      <span class="gold-bar-center"></span>
      <h3 class="text-2xl font-extrabold mb-3" style={`color: ${green}`}>Direct starten?</h3>
      <p class="mb-7" style="color: #5c5c50">Plan je opfrisles vandaag nog. Wij nemen snel contact op.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/#opfrisles-cta" class="btn-primary">
          <Icon name="calendar-check" style="font-size:13px" />
          Plan mijn opfrisles
        </a>
        <a href="tel:0152224012" class="btn-outline">
          <Icon name="phone" style="font-size:13px" />
          015-2224012
        </a>
      </div>
    </div>
  </section>

</Layout>
