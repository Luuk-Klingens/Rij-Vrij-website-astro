---
import { navbarLesgebieden } from '../data/lesgebieden';
import { getLang, getAlternateUrl } from '../i18n/utils';
import Icon from './Icon.astro';

const green        = '#223927';
const gold         = '#ac884d';
const contactPhone = '015-2224012';
const contactEmail = 'info@rij-vrij.nl';
const facebookUrl  = 'https://www.facebook.com/profile.php?id=61569989527327';
const instagramUrl = 'https://www.instagram.com/rij_vrij/';
const tiktokUrl    = 'https://www.tiktok.com/@rij.vrij/';

const lang         = getLang(Astro.url.pathname);
const isEN         = lang === 'en';
const alternateUrl = getAlternateUrl(Astro.url.pathname);

const p = (nl: string, en: string) => (isEN ? en : nl);
---

<!-- Gouden top-strip: kenmerk Dutch Design -->
<div style={`height:3px;background-color:${gold}`}></div>

<nav class="bg-white sticky top-0 z-50" style="box-shadow: 0 1px 0 #e4ddd0, 0 2px 12px rgba(34,57,39,0.06);">

  <!-- Info-balk -->
  <div class="hidden lg:block text-white text-xs font-semibold" style={`background-color: ${green}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center h-9 gap-4">

      <div class="flex items-center gap-1.5">
        {[0,1,2,3,4].map(() => <Icon name="star" class="text-yellow-400" style="font-size:10px" />)}
        <span class="ml-1">{p('5 sterren opfrislessen, direct starten', '5-star refresher lessons, start immediately')}</span>
      </div>

      <div class="flex items-center gap-6 ml-auto">
        <a href="tel:0152224012" class="flex items-center gap-1.5 hover:text-yellow-300 transition-colors">
          <Icon name="phone" style="font-size:10px" />
          {contactPhone}
        </a>
        <a href={`mailto:${contactEmail}`} class="flex items-center gap-1.5 hover:text-yellow-300 transition-colors">
          <Icon name="envelope" style="font-size:10px" />
          {contactEmail}
        </a>
        <div class="flex items-center gap-2 pl-5 border-l border-white/25">
          <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="hover:text-yellow-300 transition-colors" aria-label="Facebook">
            <Icon name="facebook" style="font-size:13px" />
          </a>
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-yellow-300 transition-colors" aria-label="Instagram">
            <Icon name="instagram" style="font-size:13px" />
          </a>
          <a href={tiktokUrl} target="_blank" rel="noopener noreferrer" class="hover:text-yellow-300 transition-colors" aria-label="TikTok">
            <Icon name="tiktok" style="font-size:13px" />
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Gouden accent-lijn onder info-balk -->
  <div class="hidden lg:block h-px" style={`background: linear-gradient(90deg, ${gold}, transparent 70%)`}></div>

  <!-- Hoofdnavigatie -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">

      <!-- Logo -->
      <a href={isEN ? '/en/' : '/'} class="flex items-center gap-3 flex-shrink-0 group">
        <img
          src="/rij-vrij-logo.png"
          alt="Rij-Vrij"
          class="h-11 lg:h-12 w-auto object-contain transition-opacity group-hover:opacity-85"
          width="120" height="120"
          loading="eager" fetchpriority="high" decoding="sync"
        />
        <span class="font-extrabold text-xl lg:text-2xl leading-none select-none" style="letter-spacing: -0.02em">
          <span style={`color: ${green}`}>Rij</span><span style={`color: ${gold}`}>-Vrij</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-0.5" id="desktop-nav">

        <!-- Over ons -->
        <div class="relative" id="dropdown-overons">
          <button class="nav-link flex items-center gap-1" id="btn-overons" aria-haspopup="true" aria-expanded="false">
            {p('Over ons', 'About')}
            <Icon name="chevron-down" class="text-[10px] transition-transform duration-200" id="chevron-overons" />
          </button>
          <div class="nav-dropdown hidden" id="menu-overons">
            <a href={p('/over-ons', '/en/about')} class="nav-dropdown-item">{p('Over ons', 'About us')}</a>
            <a href={p('/autisme-adhd', '/en/autism-adhd')} class="nav-dropdown-item">{p('Autisme & ADHD', 'Autism & ADHD')}</a>
          </div>
        </div>

        <a href={p('/diensten', '/en/services')} class="nav-link">{p('Opfrislessen', 'Refresher lessons')}</a>
        <a href={p('/prijzen', '/en/prices')} class="nav-link">{p('Tarieven', 'Prices')}</a>

        <!-- Lesgebied -->
        <div class="relative" id="dropdown-lesgebied">
          <button class="nav-link flex items-center gap-1" id="btn-lesgebied" aria-haspopup="true" aria-expanded="false">
            {p('Lesgebied', 'Areas')}
            <Icon name="chevron-down" class="text-[10px] transition-transform duration-200" id="chevron-lesgebied" />
          </button>
          <div class="nav-dropdown hidden w-[420px]" id="menu-lesgebied">
            <div class="grid grid-cols-2 gap-0.5">
              {navbarLesgebieden.map((g) => (
                <a href={isEN ? `/en/area/${g.slug}` : `/lesgebied/${g.slug}`} class="nav-dropdown-item flex items-center gap-2">
                  <Icon name="map-pin" class="opacity-40 flex-shrink-0" style="font-size:10px" />
                  {g.naam}
                </a>
              ))}
            </div>
            <div class="border-t mt-1 pt-1" style="border-color: #e4ddd0">
              <a href={isEN ? '/en/areas' : '/lesgebied'} class="flex items-center gap-1.5 px-3 py-2 text-xs font-bold transition-colors hover:opacity-80" style={`color: ${gold}`}>
                <Icon name="map" style="font-size:11px" />
                {p('Alle lesgebieden bekijken →', 'View all areas →')}
              </a>
            </div>
          </div>
        </div>

        <a href={p('/faq', '/en/faq')} class="nav-link">FAQ</a>

        <!-- CTA knop: goud gevuld, groene tekst -->
        <a
          href={p('/contact', '/en/contact')}
          class="ml-3 px-5 py-2.5 text-sm font-bold flex items-center gap-2 transition-all duration-150 hover:-translate-y-0.5"
          style={`background-color: ${gold}; color: ${green}; border-radius: 4px; box-shadow: 0 2px 12px rgba(172,136,77,0.25)`}
        >
          <Icon name="calendar-check" style="font-size:11px" />
          {p('Plan opfrisles', 'Book lesson')}
        </a>

        <!-- Taalwisselaar -->
        <a
          href={alternateUrl}
          class="ml-1 px-3 py-2 text-xs font-bold transition-all hover:opacity-75"
          style={`border: 2px solid ${green}; color: ${green}; border-radius: 4px`}
        >
          {isEN ? 'NL' : 'EN'}
        </a>
      </div>

      <!-- Hamburger -->
      <button id="mobile-menu-toggle" class="lg:hidden p-2 rounded transition-colors hover:bg-gray-100" aria-label="Menu">
        <Icon name="bars" class="text-xl" style={`color: ${green}`} />
      </button>
    </div>
  </div>

  <!-- Mobiel menu -->
  <div class="lg:hidden border-t bg-white shadow-lg max-h-[80vh] overflow-y-auto hidden" id="mobile-menu" style="border-color: #e4ddd0">
    <div class="px-3 py-3 space-y-0.5">

      <div>
        <button class="mobile-nav-btn w-full flex items-center justify-between" id="mobile-btn-overons">
          {p('Over ons', 'About')}
          <Icon name="chevron-down" class="text-xs transition-transform duration-200" id="mobile-chevron-overons" />
        </button>
        <div class="ml-4 mt-1 space-y-0.5 border-l-2 pl-3 hidden" id="mobile-menu-overons" style={`border-color: ${gold}`}>
          <a href={p('/over-ons', '/en/about')} class="mobile-nav-sub">{p('Over ons', 'About us')}</a>
          <a href={p('/autisme-adhd', '/en/autism-adhd')} class="mobile-nav-sub">{p('Autisme & ADHD', 'Autism & ADHD')}</a>
        </div>
      </div>

      <a href={p('/diensten', '/en/services')} class="mobile-nav-btn block">{p('Opfrislessen', 'Refresher lessons')}</a>
      <a href={p('/prijzen', '/en/prices')} class="mobile-nav-btn block">{p('Tarieven', 'Prices')}</a>

      <div>
        <button class="mobile-nav-btn w-full flex items-center justify-between" id="mobile-btn-lesgebied">
          {p('Lesgebied', 'Areas')}
          <Icon name="chevron-down" class="text-xs transition-transform duration-200" id="mobile-chevron-lesgebied" />
        </button>
        <div class="ml-4 mt-1 space-y-0.5 border-l-2 pl-3 hidden" id="mobile-menu-lesgebied" style={`border-color: ${gold}`}>
          {navbarLesgebieden.map((g) => (
            <a href={isEN ? `/en/area/${g.slug}` : `/lesgebied/${g.slug}`} class="mobile-nav-sub">{g.naam}</a>
          ))}
          <a href={isEN ? '/en/areas' : '/lesgebied'} class="mobile-nav-sub font-bold" style={`color: ${gold}`}>
            {p('Alle lesgebieden →', 'All areas →')}
          </a>
        </div>
      </div>

      <a href={p('/faq', '/en/faq')} class="mobile-nav-btn block">FAQ</a>

      <div class="pt-3 mt-2 border-t space-y-2" style="border-color: #e4ddd0">
        <a href="tel:0152224012" class="flex items-center gap-2 px-3 py-2.5 text-sm transition-colors hover:bg-gray-50" style={`color: ${green}`}>
          <Icon name="phone" style="font-size:11px" /> {contactPhone}
        </a>
        <a href={`mailto:${contactEmail}`} class="flex items-center gap-2 px-3 py-2.5 text-sm transition-colors hover:bg-gray-50" style={`color: ${green}`}>
          <Icon name="envelope" style="font-size:11px" /> {contactEmail}
        </a>
        <a
          href={p('/contact', '/en/contact')}
          class="block text-center text-sm font-bold px-4 py-3"
          style={`background-color: ${gold}; color: ${green}; border-radius: 4px`}
        >
          {p('Plan je opfrisles', 'Book a refresher lesson')}
        </a>
        <a
          href={alternateUrl}
          class="block text-center text-sm font-bold px-4 py-2.5 border-2 transition-all"
          style={`border-color: ${green}; color: ${green}; border-radius: 4px`}
        >
          {isEN ? 'NL' : 'EN'}
        </a>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav-link {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a18;
    border-radius: 4px;
    transition: color 0.12s, background-color 0.12s;
    white-space: nowrap;
  }
  .nav-link:hover { color: #223927; background-color: rgba(34,57,39,0.06); }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 0.375rem);
    left: 0;
    min-width: 13rem;
    background: white;
    border-radius: 4px;
    box-shadow: 0 8px 32px rgba(34,57,39,0.12), 0 1px 4px rgba(34,57,39,0.06);
    border: 1px solid #e4ddd0;
    border-top: 3px solid #ac884d;
    padding: 0.5rem;
    z-index: 50;
  }

  .nav-dropdown-item {
    display: block;
    padding: 0.625rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #374151;
    border-radius: 3px;
    transition: background-color 0.12s, color 0.12s;
  }
  .nav-dropdown-item:hover { background-color: #223927; color: white; }

  .mobile-nav-btn {
    padding: 0.625rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #1a1a18;
    border-radius: 4px;
    transition: background-color 0.12s;
  }
  .mobile-nav-btn:hover { background-color: rgba(34,57,39,0.05); }

  .mobile-nav-sub {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    color: #4B5563;
    border-radius: 3px;
    transition: background-color 0.12s, color 0.12s;
  }
  .mobile-nav-sub:hover { background-color: rgba(34,57,39,0.05); color: #223927; }
</style>

<script>
  document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });

  function setupMobileSubmenu(btnId: string, menuId: string, chevronId: string) {
    const btn    = document.getElementById(btnId);
    const menu   = document.getElementById(menuId);
    const chevron = document.getElementById(chevronId);
    btn?.addEventListener('click', () => {
      const open = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', open);
      chevron?.classList.toggle('rotate-180', !open);
    });
  }
  setupMobileSubmenu('mobile-btn-overons',   'mobile-menu-overons',   'mobile-chevron-overons');
  setupMobileSubmenu('mobile-btn-lesgebied', 'mobile-menu-lesgebied', 'mobile-chevron-lesgebied');

  function setupDesktopDropdown(btnId: string, menuId: string, chevronId: string) {
    const btn    = document.getElementById(btnId);
    const menu   = document.getElementById(menuId);
    const chevron = document.getElementById(chevronId);
    const parent = btn?.parentElement;
    let t: ReturnType<typeof setTimeout>;
    const show = () => { clearTimeout(t); menu?.classList.remove('hidden'); chevron?.classList.add('rotate-180'); };
    const hide = () => { t = setTimeout(() => { menu?.classList.add('hidden'); chevron?.classList.remove('rotate-180'); }, 150); };
    parent?.addEventListener('mouseenter', show);
    parent?.addEventListener('mouseleave', hide);
    menu?.addEventListener('mouseenter', show);
    menu?.addEventListener('mouseleave', hide);
  }
  setupDesktopDropdown('btn-overons',   'menu-overons',   'chevron-overons');
  setupDesktopDropdown('btn-lesgebied', 'menu-lesgebied', 'chevron-lesgebied');
</script>
