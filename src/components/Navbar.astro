---
import { navbarLesgebieden } from '../data/lesgebieden';
import { getLang, getAlternateUrl } from '../i18n/utils';

const primaryColor = '#0391b0';
const secondaryColor = '#790f34';
const topBarColor = '#027a93';
const contactPhone = '015-2224012';
const contactEmail = 'info@Rij-Vrij.com';
const facebookUrl = 'https://www.facebook.com/profile.php?id=61569989527327';
const instagramUrl = 'https://www.instagram.com/autorijschool_auto_maat/';
const tiktokUrl = 'https://www.tiktok.com/@autorijschool.auto_maat';

const lang = getLang(Astro.url.pathname);
const isEN = lang === 'en';
const alternateUrl = getAlternateUrl(Astro.url.pathname);

const p = (nl: string, en: string) => (isEN ? en : nl);
const base = isEN ? '/en' : '';
import Icon from './Icon.astro';
---

<nav class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
  <!-- Top bar (desktop only) -->
  <div class="hidden lg:block border-b border-black/10 text-white shadow-sm" style={`background-color: ${topBarColor}`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center h-11 gap-4 text-sm font-semibold">
      <!-- Sterren links -->
      <div class="flex items-center gap-2">
        <div class="flex items-center gap-0.5">
          <Icon name="star" class="text-yellow-400 text-xs" />
          <Icon name="star" class="text-yellow-400 text-xs" />
          <Icon name="star" class="text-yellow-400 text-xs" />
          <Icon name="star" class="text-yellow-400 text-xs" />
          <Icon name="star" class="text-yellow-400 text-xs" />
        </div>
        <span class="text-white text-xs font-semibold">{p('Door leerlingen beoordeeld met 5 sterren', 'Rated 5 stars by our students')}</span>
      </div>
      <!-- Rechts: contact + socials + CBR -->
      <div class="flex items-center gap-4">
      <a href="tel:0152224012" class="flex items-center gap-1.5 text-white hover:text-white/80 transition-colors">
        <Icon name="phone" class="text-xs" />
        {contactPhone}
      </a>
      <a href={`mailto:${contactEmail}`} class="flex items-center gap-1.5 text-white hover:text-white/80 transition-colors">
        <Icon name="envelope" class="text-xs" />
        {contactEmail}
      </a>
      <div class="flex items-center gap-2 border-l border-white/20 pl-3">
        <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="text-white hover:text-white/80 transition-colors" aria-label="Facebook">
          <Icon name="facebook" class="text-base" />
        </a>
        <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="text-white hover:text-white/80 transition-colors" aria-label="Instagram">
          <Icon name="instagram" class="text-base" />
        </a>
        <a href={tiktokUrl} target="_blank" rel="noopener noreferrer" class="text-white hover:text-white/80 transition-colors" aria-label="TikTok">
          <Icon name="tiktok" class="text-base" />
        </a>
      </div>
      <span class="border-l border-white/20 pl-3 text-white">CBR Opleidersnummer: 1460F3</span>
      </div>
    </div>
  </div>

  <!-- Main nav -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <a href={isEN ? '/en/' : '/'} class="flex items-center group flex-shrink-0">
        <picture>
          <source srcset="/RijVrij-logo.webp" type="image/webp" />
          <img
            src="/RijVrij-logo-png.png"
            alt="Rij-Vrij"
            class="h-14 lg:h-16 w-auto object-contain transition-opacity group-hover:opacity-80"
            width="400"
            height="105"
            loading="eager"
            fetchpriority="high"
            decoding="sync"
          />
        </picture>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1" id="desktop-nav">

        <!-- Over ons dropdown -->
        <div class="relative group" id="dropdown-overons">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition-all"
            style={`background-color: ${secondaryColor}`}
            id="btn-overons"
            aria-haspopup="true"
            aria-expanded="false"
          >
            {p('Over ons', 'About')}
            <Icon name="chevron-down" class="text-xs transition-transform" id="chevron-overons" />
          </button>
          <div
            class="absolute top-full left-0 mt-1 w-52 bg-white rounded-xl shadow-xl border border-gray-100 py-2 z-50 hidden"
            id="menu-overons"
          >
            <a href={p('/over-ons', '/en/about')} class="block px-4 py-2.5 text-sm font-semibold text-gray-700 hover:text-white transition-colors rounded-lg mx-1 nav-dropdown-item" style={`--hover-bg: ${primaryColor}`}>{p('Over ons', 'About us')}</a>
            <a href={p('/autisme-adhd', '/en/autism-adhd')} class="block px-4 py-2.5 text-sm font-semibold text-gray-700 hover:text-white transition-colors rounded-lg mx-1 nav-dropdown-item" style={`--hover-bg: ${primaryColor}`}>{p('Autisme & ADHD', 'Autism & ADHD')}</a>
          </div>
        </div>

        <a href={p('/prijzen', '/en/prices')} class="px-3 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition-all" style={`background-color: ${secondaryColor}`}>{p('Tarieven', 'Prices')}</a>

        <!-- Lesgebied dropdown -->
        <div class="relative" id="dropdown-lesgebied">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition-all"
            style={`background-color: ${secondaryColor}`}
            id="btn-lesgebied"
            aria-haspopup="true"
            aria-expanded="false"
          >
            {p('Lesgebied', 'Areas')}
            <Icon name="chevron-down" class="text-xs transition-transform" id="chevron-lesgebied" />
          </button>
          <div
            class="absolute top-full left-0 mt-1 w-[400px] bg-white rounded-xl shadow-xl border border-gray-100 p-2 z-50 hidden"
            id="menu-lesgebied"
          >
            <div class="grid grid-cols-2 gap-0.5">
              {navbarLesgebieden.map((g) => (
                <a
                  href={isEN ? `/en/area/${g.slug}` : `/lesgebied/${g.slug}`}
                  class="flex items-center gap-2 px-3 py-2 text-xs font-semibold text-gray-700 hover:text-white transition-colors rounded-lg nav-dropdown-item"
                >
                  <Icon name="map-pin" class="text-xs flex-shrink-0" />
                  {g.naam}
                </a>
              ))}
            </div>
            <div class="border-t border-gray-100 mt-1.5 pt-1.5">
              <a
                href={isEN ? '/en/areas' : '/lesgebied'}
                class="flex items-center gap-1.5 px-3 py-2 text-xs font-semibold transition-colors rounded-lg nav-dropdown-item"
                style={`color: ${primaryColor}`}
              >
                <Icon name="map" class="text-xs flex-shrink-0" />{p('Alle lesgebieden →', 'All areas →')}
              </a>
            </div>
          </div>
        </div>

        <a href={p('/onmyway-app', '/en/onmyway')} class="px-3 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition-all" style={`background-color: ${secondaryColor}`}>OnMyWay</a>

        <!-- Examens dropdown -->
        <div class="relative" id="dropdown-examens">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition-all"
            style={`background-color: ${secondaryColor}`}
            id="btn-examens"
            aria-haspopup="true"
            aria-expanded="false"
          >
            {p('Examens', 'Exams')}
            <Icon name="chevron-down" class="text-xs transition-transform" id="chevron-examens" />
          </button>
          <div
            class="absolute top-full left-0 mt-1 w-52 bg-white rounded-xl shadow-xl border border-gray-100 py-2 z-50 hidden"
            id="menu-examens"
          >
            <a href={p('/examen-theorie', '/en/theory-exam')} class="block px-4 py-2.5 text-sm font-semibold text-gray-700 hover:text-white transition-colors rounded-lg mx-1 nav-dropdown-item">{p('Theorie', 'Theory')}</a>
            <a href={p('/examen-praktijk', '/en/practical-exam')} class="block px-4 py-2.5 text-sm font-semibold text-gray-700 hover:text-white transition-colors rounded-lg mx-1 nav-dropdown-item">{p('Praktijk', 'Practical')}</a>
            <a href={p('/rijschool-machtigen', '/en/authorize')} class="block px-4 py-2.5 text-sm font-semibold text-gray-700 hover:text-white transition-colors rounded-lg mx-1 nav-dropdown-item">{p('Rijschool machtigen', 'Authorize school')}</a>
            <a href={p('/gezondheidsverklaring', '/en/health-declaration')} class="block px-4 py-2.5 text-sm font-semibold text-gray-700 hover:text-white transition-colors rounded-lg mx-1 nav-dropdown-item">{p('Gezondheidsverklaring', 'Health declaration')}</a>
          </div>
        </div>

        <a href={p('/vacatures', '/en/vacancies')} class="px-3 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition-all" style={`background-color: ${secondaryColor}`}>{p('Vacatures', 'Vacancies')}</a>
        <a href={p('/faq', '/en/faq')} class="px-3 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition-all" style={`background-color: ${secondaryColor}`}>FAQ</a>

        <!-- Contact CTA -->
        <a
          href={p('/contact', '/en/contact')}
          class="ml-2 px-4 py-2 text-sm font-semibold text-white rounded-lg hover:opacity-90 transition-all shadow-md flex items-center gap-2"
          style={`background-color: ${primaryColor}`}
        >
          <Icon name="envelope" class="text-xs" />
          Contact
        </a>

        <!-- Language switcher -->
        <a
          href={alternateUrl}
          class="ml-1 px-3 py-2 text-xs font-bold border-2 rounded-lg transition-all hover:opacity-80"
          style={`border-color: ${primaryColor}; color: ${primaryColor}`}
          title={isEN ? 'Nederlands' : 'English'}
        >
          {isEN ? 'NL' : 'EN'}
        </a>
      </div>

      <!-- Hamburger button -->
      <div class="flex items-center gap-3">
        <button
          id="mobile-menu-toggle"
          class="lg:hidden text-gray-700 hover:opacity-75 focus:outline-none p-2"
          aria-label="Menu"
        >
          <Icon name="bars" class="text-xl" id="hamburger-icon" />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="lg:hidden border-t border-gray-100 bg-white shadow-lg max-h-[80vh] overflow-y-auto hidden" id="mobile-menu">
    <div class="px-3 py-3 space-y-1">

      <!-- Over ons mobile -->
      <div>
        <button
          class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition-colors"
          id="mobile-btn-overons"
        >
          {p('Over ons', 'About')}
          <Icon name="chevron-down" class="text-xs transition-transform" id="mobile-chevron-overons" />
        </button>
        <div class="ml-4 mt-1 space-y-1 border-l-2 pl-3 hidden" id="mobile-menu-overons" style={`border-color: ${primaryColor}`}>
          <a href={p('/over-ons', '/en/about')} class="block px-3 py-2 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 transition-colors">{p('Over ons', 'About us')}</a>
          <a href={p('/autisme-adhd', '/en/autism-adhd')} class="block px-3 py-2 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 transition-colors">{p('Autisme & ADHD', 'Autism & ADHD')}</a>
        </div>
      </div>

      <a href={p('/prijzen', '/en/prices')} class="block px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">{p('Tarieven', 'Prices')}</a>

      <!-- Lesgebied mobile -->
      <div>
        <button
          class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition-colors"
          id="mobile-btn-lesgebied"
        >
          {p('Lesgebied', 'Areas')}
          <Icon name="chevron-down" class="text-xs transition-transform" id="mobile-chevron-lesgebied" />
        </button>
        <div class="ml-4 mt-1 space-y-1 border-l-2 pl-3 hidden" id="mobile-menu-lesgebied" style={`border-color: ${primaryColor}`}>
          {navbarLesgebieden.map((g) => (
            <a href={isEN ? `/en/area/${g.slug}` : `/lesgebied/${g.slug}`} class="block px-3 py-2 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 transition-colors">{g.naam}</a>
          ))}
          <a href={isEN ? '/en/areas' : '/lesgebied'} class="block px-3 py-2 text-sm font-semibold hover:bg-gray-50 rounded-lg transition-colors" style={`color: ${primaryColor}`}>
            <Icon name="map" class="mr-1 text-xs" />{p('Alle lesgebieden', 'All areas')}
          </a>
        </div>
      </div>

      <a href={p('/onmyway-app', '/en/onmyway')} class="block px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">OnMyWay</a>

      <!-- Examens mobile -->
      <div>
        <button
          class="flex items-center justify-between w-full px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition-colors"
          id="mobile-btn-examens"
        >
          {p('Examens', 'Exams')}
          <Icon name="chevron-down" class="text-xs transition-transform" id="mobile-chevron-examens" />
        </button>
        <div class="ml-4 mt-1 space-y-1 border-l-2 pl-3 hidden" id="mobile-menu-examens" style={`border-color: ${primaryColor}`}>
          <a href={p('/examen-theorie', '/en/theory-exam')} class="block px-3 py-2 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 transition-colors">{p('Theorie', 'Theory')}</a>
          <a href={p('/examen-praktijk', '/en/practical-exam')} class="block px-3 py-2 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 transition-colors">{p('Praktijk', 'Practical')}</a>
          <a href={p('/rijschool-machtigen', '/en/authorize')} class="block px-3 py-2 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 transition-colors">{p('Rijschool machtigen', 'Authorize school')}</a>
          <a href={p('/gezondheidsverklaring', '/en/health-declaration')} class="block px-3 py-2 text-sm text-gray-600 hover:text-gray-900 rounded-lg hover:bg-gray-50 transition-colors">{p('Gezondheidsverklaring', 'Health declaration')}</a>
        </div>
      </div>

      <a href={p('/vacatures', '/en/vacancies')} class="block px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">{p('Vacatures', 'Vacancies')}</a>
      <a href={p('/faq', '/en/faq')} class="block px-3 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 rounded-lg transition-colors">FAQ</a>

      <div class="pt-2 border-t border-gray-100 mt-2">
        <a href="tel:0152224012" class="flex items-center gap-2 px-3 py-2.5 text-sm text-gray-700 hover:bg-gray-50 rounded-lg">
          <Icon name="phone" class="text-xs" style={`color: ${primaryColor}`} />
          {contactPhone}
        </a>
        <a href={`mailto:${contactEmail}`} class="flex items-center gap-2 px-3 py-2.5 text-sm text-gray-700 hover:bg-gray-50 rounded-lg">
          <Icon name="envelope" class="text-xs" style={`color: ${primaryColor}`} />
          {contactEmail}
        </a>
        <a
          href={p('/contact', '/en/contact')}
          class="block text-white text-sm font-semibold text-center mt-2 px-4 py-3 rounded-lg shadow-md"
          style={`background-color: ${secondaryColor}`}
        >
          {p('Plan je proefles', 'Book a trial lesson')}
        </a>
        <a
          href={alternateUrl}
          class="block text-center mt-2 px-4 py-2.5 text-sm font-bold rounded-lg border-2 transition-all"
          style={`border-color: ${primaryColor}; color: ${primaryColor}`}
        >
          {isEN ? '🇳🇱 Nederlands' : '🇬🇧 English'}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const primaryColor = '#0391b0';

  // Mobile menu toggle
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');

  mobileToggle?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('fa-times');
      hamburgerIcon?.classList.add('fa-bars');
    } else {
      mobileMenu?.classList.remove('hidden');
      hamburgerIcon?.classList.remove('fa-bars');
      hamburgerIcon?.classList.add('fa-times');
    }
  });

  // Mobile submenu toggles
  function setupMobileSubmenu(btnId: string, menuId: string, chevronId: string) {
    const btn = document.getElementById(btnId);
    const menu = document.getElementById(menuId);
    const chevron = document.getElementById(chevronId);
    btn?.addEventListener('click', () => {
      const isOpen = !menu?.classList.contains('hidden');
      if (isOpen) {
        menu?.classList.add('hidden');
        chevron?.classList.remove('rotate-180');
      } else {
        menu?.classList.remove('hidden');
        chevron?.classList.add('rotate-180');
      }
    });
  }

  setupMobileSubmenu('mobile-btn-overons', 'mobile-menu-overons', 'mobile-chevron-overons');
  setupMobileSubmenu('mobile-btn-examens', 'mobile-menu-examens', 'mobile-chevron-examens');
  setupMobileSubmenu('mobile-btn-lesgebied', 'mobile-menu-lesgebied', 'mobile-chevron-lesgebied');

  // Desktop dropdown hover
  function setupDesktopDropdown(btnId: string, menuId: string, chevronId: string) {
    const btn = document.getElementById(btnId);
    const menu = document.getElementById(menuId);
    const chevron = document.getElementById(chevronId);
    let timeout: ReturnType<typeof setTimeout>;

    const parent = btn?.parentElement;

    const show = () => {
      clearTimeout(timeout);
      menu?.classList.remove('hidden');
      chevron?.classList.add('rotate-180');
    };
    const hide = () => {
      timeout = setTimeout(() => {
        menu?.classList.add('hidden');
        chevron?.classList.remove('rotate-180');
      }, 150);
    };

    parent?.addEventListener('mouseenter', show);
    parent?.addEventListener('mouseleave', hide);
    menu?.addEventListener('mouseenter', show);
    menu?.addEventListener('mouseleave', hide);
  }

  setupDesktopDropdown('btn-overons', 'menu-overons', 'chevron-overons');
  setupDesktopDropdown('btn-examens', 'menu-examens', 'chevron-examens');
  setupDesktopDropdown('btn-lesgebied', 'menu-lesgebied', 'chevron-lesgebied');

  // Dropdown item hover colors
  document.querySelectorAll('.nav-dropdown-item').forEach((el) => {
    (el as HTMLElement).addEventListener('mouseenter', () => {
      (el as HTMLElement).style.backgroundColor = primaryColor;
      (el as HTMLElement).style.color = 'white';
    });
    (el as HTMLElement).addEventListener('mouseleave', () => {
      (el as HTMLElement).style.backgroundColor = '';
      (el as HTMLElement).style.color = '';
    });
  });
</script>
