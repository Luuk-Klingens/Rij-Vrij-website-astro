---
const green        = '#223927';
const gold         = '#ac884d';
const currentYear  = new Date().getFullYear();
const contactPhone = '015-2224012';
const contactEmail = 'info@rij-vrij.nl';
const facebookUrl  = 'https://www.facebook.com/profile.php?id=61569989527327';
const instagramUrl = 'https://www.instagram.com/rij_vrij/';
const tiktokUrl    = 'https://www.tiktok.com/@rij.vrij/';
import Icon from './Icon.astro';
---

<!-- Diagonale bovenkant: goud parallelogram als overgang -->
<div style={`background-color: ${green}; overflow: hidden; height: 3rem`}>
  <svg viewBox="0 0 1440 48" preserveAspectRatio="none" style="width:100%;height:100%;display:block;">
    <path d="M0,0 L1440,0 L1440,48 L0,0 Z" fill="#faf8f4" />
  </svg>
</div>

<footer style={`background-color: ${green}`} class="text-white">

  <!-- Gouden scheidingslijn bovenaan footer-content -->
  <div style={`background: linear-gradient(90deg, ${gold}, transparent 60%); height: 3px`}></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-10">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

      <!-- Kolom 1: Logo & intro -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-3 mb-5">
          <img
            src="/rij-vrij-logo.png"
            alt="Rij-Vrij"
            class="h-10 w-auto object-contain"
            width="40" height="40" loading="lazy"
          />
          <span class="font-extrabold text-xl leading-none" style="letter-spacing: -0.02em">
            <span class="text-white">Rij</span><span style={`color: ${gold}`}>-Vrij</span>
          </span>
        </div>
        <p class="text-sm mb-5 leading-relaxed" style="color: rgba(255,255,255,0.6)">
          Professionele opfrislessen in automaat. Regio Haaglanden, Delft &amp; Zoetermeer. Specialist autisme &amp; ADHD.
        </p>
        <!-- Gouden accent-streep -->
        <div style={`width: 2rem; height: 3px; background-color: ${gold}; margin-bottom: 1rem`}></div>
        <ul class="space-y-1 text-sm" style="color: rgba(255,255,255,0.5)">
          {[
            ['bergschenhoek','Bergschenhoek'],['berkel-en-rodenrijs','Berkel en Rodenrijs'],
            ['bleiswijk','Bleiswijk'],['delfgauw','Delfgauw'],['delft','Delft'],
            ['leidschenveen','Leidschenveen'],['nootdorp','Nootdorp'],['pijnacker','Pijnacker'],
            ['rijswijk','Rijswijk'],['voorburg','Voorburg'],['ypenburg','Ypenburg'],
            ['zoetermeer','Zoetermeer'],
          ].map(([slug, naam]) => (
            <li><a href={`/lesgebied/${slug}`} class="footer-link">Opfrislessen {naam}</a></li>
          ))}
        </ul>
      </div>

      <!-- Kolom 2: Contact -->
      <div>
        <h2 class="text-base font-bold mb-5 flex items-center gap-2 uppercase tracking-widest" style={`color: ${gold}; font-size: 0.75rem`}>
          Contact
        </h2>
        <ul class="space-y-3.5 text-sm" style="color: rgba(255,255,255,0.7)">
          <li>
            <a href={`mailto:${contactEmail}`} class="footer-link flex items-center gap-2.5">
              <Icon name="envelope" style={`color: ${gold}; font-size:13px; flex-shrink:0`} />
              {contactEmail}
            </a>
          </li>
          <li>
            <a href="tel:0152224012" class="footer-link flex items-center gap-2.5">
              <Icon name="phone" style={`color: ${gold}; font-size:13px; flex-shrink:0`} />
              {contactPhone}
            </a>
          </li>
          <li class="flex items-start gap-2.5">
            <Icon name="map-marker-alt" style={`color: ${gold}; font-size:13px; flex-shrink:0; margin-top:2px`} />
            <span>Hankweg 39<br />2641 WV Pijnacker</span>
          </li>
          <li class="flex items-center gap-2.5">
            <Icon name="clock" style={`color: ${gold}; font-size:13px; flex-shrink:0`} />
            <span>Ma – Vr: 8:00 – 17:00</span>
          </li>
        </ul>
      </div>

      <!-- Kolom 3: Juridisch -->
      <div>
        <h2 class="text-base font-bold mb-5 uppercase tracking-widest" style={`color: ${gold}; font-size: 0.75rem`}>
          Juridisch
        </h2>
        <ul class="space-y-3.5 text-sm" style="color: rgba(255,255,255,0.7)">
          <li class="flex items-center gap-2.5">
            <Icon name="building" style={`color: ${gold}; font-size:13px; flex-shrink:0`} />
            <span>KVK: 62968157</span>
          </li>
          <li class="flex items-center gap-2.5">
            <Icon name="file-invoice" style={`color: ${gold}; font-size:13px; flex-shrink:0`} />
            <span>BTW: NL004762677B86</span>
          </li>
          <li>
            <a href="/algemene-voorwaarden" class="footer-link flex items-center gap-2.5">
              <Icon name="file-contract" style={`color: ${gold}; font-size:13px; flex-shrink:0`} />
              Algemene voorwaarden
            </a>
          </li>
          <li>
            <a href="/privacy-voorwaarden" class="footer-link flex items-center gap-2.5">
              <Icon name="shield-alt" style={`color: ${gold}; font-size:13px; flex-shrink:0`} />
              Privacybeleid
            </a>
          </li>
        </ul>
      </div>

      <!-- Kolom 4: Social media -->
      <div>
        <h2 class="text-base font-bold mb-5 uppercase tracking-widest" style={`color: ${gold}; font-size: 0.75rem`}>
          Volg ons
        </h2>
        <div class="flex flex-col gap-2.5">
          <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="social-card">
            <Icon name="facebook" class="text-blue-400 text-xl flex-shrink-0" />
            <div>
              <p class="font-bold text-sm text-white">Facebook</p>
              <p class="text-xs" style="color: rgba(255,255,255,0.5)">Rij-Vrij Rijschool</p>
            </div>
          </a>
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="social-card">
            <Icon name="instagram" class="text-pink-400 text-xl flex-shrink-0" />
            <div>
              <p class="font-bold text-sm text-white">Instagram</p>
              <p class="text-xs" style="color: rgba(255,255,255,0.5)">@rij_vrij</p>
            </div>
          </a>
          <a href={tiktokUrl} target="_blank" rel="noopener noreferrer" class="social-card">
            <Icon name="tiktok" class="text-white text-xl flex-shrink-0" />
            <div>
              <p class="font-bold text-sm text-white">TikTok</p>
              <p class="text-xs" style="color: rgba(255,255,255,0.5)">@rij.vrij</p>
            </div>
          </a>
        </div>
      </div>

    </div>

    <!-- Copyright balk -->
    <div class="border-t pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs" style="border-color: rgba(172,136,77,0.25); color: rgba(255,255,255,0.4)">
      <div class="flex items-center gap-4">
        <p>&copy; {currentYear} Rij-Vrij Opfrislessen</p>
        <div class="flex items-center gap-3">
          <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors" aria-label="Facebook"><Icon name="facebook" style="font-size:15px" /></a>
          <a href={instagramUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors" aria-label="Instagram"><Icon name="instagram" style="font-size:15px" /></a>
          <a href={tiktokUrl} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors" aria-label="TikTok"><Icon name="tiktok" style="font-size:15px" /></a>
        </div>
      </div>
      <p>Website door <a href="https://luukklingens.com" target="_blank" rel="noopener noreferrer" class="font-bold hover:text-white transition-colors">Luuk Klingens</a></p>
    </div>

  </div>
</footer>

<style>
  .footer-link { transition: color 0.12s; }
  .footer-link:hover { color: white; }

  .social-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.75rem 1rem;
    border-left: 3px solid #ac884d;
    background-color: rgba(255,255,255,0.05);
    transition: background-color 0.12s;
  }
  .social-card:hover {
    background-color: rgba(255,255,255,0.1);
  }
</style>
